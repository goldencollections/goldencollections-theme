{%- liquid
  assign collection_template_suffix = collection.template_suffix | default: ''
  assign is_deity_schema_collection = false
  if collection_template_suffix contains 'deity' or collection_template_suffix == 'varalakshmi'
    assign is_deity_schema_collection = true
  endif
-%}
{%- if is_deity_schema_collection -%}
  {%- assign deity_collection_url = collections['deity-jewelry'].url | default: routes.collections_url -%}
  {%- liquid
    assign collection_handle = collection.handle | downcase
    assign collection_title = collection.title | downcase
    assign is_performance_crown_collection = false
    assign schema_parent_label = 'Deity Jewellery'
    if collection_handle contains 'drama-dance-crowns' or collection_title contains 'drama crown' or collection_title contains 'dance crown'
      assign is_performance_crown_collection = true
      assign deity_collection_url = collections['bharatanatyam-jewellery'].url | default: routes.collections_url
      assign schema_parent_label = 'Bharatanatyam Jewellery'
    endif
    assign family_menu_handle = collection.metafields.custom.parent_menu_handles.value | default: ''
    assign family_menu_handle = family_menu_handle | downcase | strip | split: ',' | first | strip
    assign collection_intro = collection.metafields.custom.collection_intro.value | default: collection.metafields.custom.collection_intro | default: collection.metafields.custom.collection_intent.value | default: collection.metafields.custom.collection_intent
    assign faq_family_metafield = collection.metafields.custom.faq_family.value | default: collection.metafields.custom.faq_family
    assign collection_deity_group_ref = collection.metafields.custom.primary_deity_ref.value | default: collection.metafields.custom.deity_group.value
    assign collection_deity_group = collection_deity_group_ref.name.value | default: collection_deity_group_ref.name | default: collection.metafields.custom.deity_group.value | default: collection.metafields.custom.deity_group
    assign collection_ornament_type_ref = collection.metafields.custom.ornament_type_ref.value | default: collection.metafields.custom.ornament_type.value
    assign collection_ornament_type = collection_ornament_type_ref.name.value | default: collection_ornament_type_ref.name | default: collection.metafields.custom.ornament_type.value | default: collection.metafields.custom.ornament_type
    assign faq_family_source = faq_family_metafield
    if faq_family_source == blank
      assign faq_family_source = collection_deity_group | append: ' ' | append: collection_ornament_type
    endif
    assign faq_family_source = faq_family_source | downcase | strip
    assign faq_family = ''

    if is_performance_crown_collection
      assign faq_family = 'dance_crown'
    elsif faq_family_source contains 'banana' or faq_family_source contains 'plantain' or faq_family_source contains 'vazhai' or faq_family_source contains 'vazhamaram'
      assign faq_family = 'banana_decor'
    elsif faq_family_source contains 'varalakshmi' or faq_family_source contains 'vara lakshmi' or faq_family_source contains 'vara-lakshmi' or faq_family_source contains 'lakshmi'
      assign faq_family = 'varalakshmi'
    elsif faq_family_source contains 'decor' or faq_family_source contains 'decoration' or faq_family_source contains 'arch' or faq_family_source contains 'prabhavali' or faq_family_source contains 'stand' or faq_family_source contains 'asana'
      assign faq_family = 'decor'
    elsif faq_family_source contains 'vishnu' or faq_family_source contains 'perumal' or faq_family_source contains 'balaji' or faq_family_source contains 'venkateswara' or faq_family_source contains 'shankh' or faq_family_source contains 'chakra'
      assign faq_family = 'vishnu'
    elsif faq_family_source contains 'crown' or faq_family_source contains 'mukut' or faq_family_source contains 'kireed'
      assign faq_family = 'crown'
    elsif faq_family_source contains 'necklace' or faq_family_source contains 'haram' or faq_family_source contains 'pustal' or faq_family_source contains 'pendant'
      assign faq_family = 'necklace'
    elsif faq_family_source contains 'waist' or faq_family_source contains 'vaddanam' or faq_family_source contains 'oddiyanam'
      assign faq_family = 'waist'
    elsif faq_family_source contains 'earring' or faq_family_source contains 'karna'
      assign faq_family = 'earrings'
    elsif faq_family_source contains 'accessory' or faq_family_source contains 'eyes' or faq_family_source contains 'nose' or faq_family_source contains 'bindi' or faq_family_source contains 'tilak' or faq_family_source contains 'thiruman' or faq_family_source contains 'taira' or faq_family_source contains 'weapon' or faq_family_source contains 'hands' or faq_family_source contains 'legs'
      assign faq_family = 'accessory'
    endif

    if faq_family == blank
      if collection_handle contains 'banana' or collection_title contains 'banana' or collection_title contains 'plantain' or collection_handle contains 'vazhai'
        assign faq_family = 'banana_decor'
      elsif collection_handle contains 'varalakshmi' or collection_handle contains 'vara-lakshmi' or collection_handle contains 'vagamalai' or collection_handle contains 'hands-legs-for-varalakshmi' or collection_title contains 'varalakshmi' or collection_title contains 'varamahalakshmi' or family_menu_handle contains 'varalakshmi'
        assign faq_family = 'varalakshmi'
      elsif collection_handle contains 'banana' or collection_handle contains 'lotus' or collection_handle contains 'stand' or collection_handle contains 'asana' or collection_handle contains 'sanctum' or collection_handle contains 'singhasan' or collection_handle contains 'cushions'
        assign faq_family = 'decor'
      elsif collection_handle contains 'shankh' or collection_handle contains 'chakra' or collection_handle contains 'vishnu' or collection_handle contains 'perumal' or family_menu_handle contains 'vishnu'
        assign faq_family = 'vishnu'
      elsif collection_handle contains 'crown' or collection_handle contains 'mukut' or collection_title contains 'crown' or collection_title contains 'mukut'
        assign faq_family = 'crown'
      elsif collection_handle contains 'necklace' or collection_handle contains 'haram' or collection_handle contains 'pustal' or collection_handle contains 'pendant' or collection_title contains 'necklace' or collection_title contains 'haram'
        assign faq_family = 'necklace'
      elsif collection_handle contains 'waist' or collection_handle contains 'vaddanam' or collection_title contains 'waist' or collection_title contains 'vaddanam'
        assign faq_family = 'waist'
      elsif collection_handle contains 'earring' or collection_title contains 'earring' or collection_title contains 'karna'
        assign faq_family = 'earrings'
      elsif collection_handle contains 'eyes' or collection_handle contains 'nose' or collection_handle contains 'bindi' or collection_handle contains 'tilak' or collection_handle contains 'thiruman' or collection_handle contains 'taira' or collection_handle contains 'mustache' or collection_handle contains 'weapons' or collection_handle contains 'accessories'
        assign faq_family = 'accessory'
      endif
    endif

    if faq_family == blank
      assign faq_family = 'amman'
    endif
  -%}
  {%- capture collection_description -%}
    {%- if collection_intro != blank -%}
      {{ collection_intro }}
    {%- else -%}
      {%- if is_performance_crown_collection -%}
        {{ collection.title }} at Golden Collections includes drama and dance crowns for Bharatanatyam, Kuchipudi and mythological stage roles. Use measured product images, crown height, width, depth and performer hairstyle details before ordering.
      {%- else -%}
        {{ collection.title }} at Golden Collections includes deity jewellery and Hindu idol alankaram accessories selected by deity, ornament type, placement and idol size. Use measured product images and fit notes before ordering.
      {%- endif -%}
    {%- endif -%}
  {%- endcapture -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "CollectionPage",
        "@id": "{{ shop.url }}{{ collection.url }}#webpage",
        "url": "{{ shop.url }}{{ collection.url }}",
        "name": {{ collection.title | json }},
        "description": {{ collection_description | strip | json }},
        "about": [
          {%- if faq_family == 'dance_crown' -%}
            { "@type": "Thing", "name": "Bharatanatyam crown" },
            { "@type": "Thing", "name": "Kuchipudi drama crown" },
            { "@type": "Thing", "name": "Dance costume accessory" },
            { "@type": "Thing", "name": "Mythological stage headgear" }
          {%- elsif faq_family == 'banana_decor' -%}
            { "@type": "Thing", "name": "Banana tree pooja decor" },
            { "@type": "Thing", "name": "Banana bunch pooja decor" },
            { "@type": "Thing", "name": "Varalakshmi Vratham decoration" },
            { "@type": "Thing", "name": "Lakshmi Pooja decoration" },
            { "@type": "Thing", "name": "Pooja mandapam decoration" }
          {%- elsif faq_family == 'varalakshmi' -%}
            { "@type": "Thing", "name": "Varalakshmi idol" },
            { "@type": "Thing", "name": "Varamahalakshmi doll" },
            { "@type": "Thing", "name": "Ammavaru bommai" },
            { "@type": "Thing", "name": "Lakshmi Amman pooja setup" }
          {%- else -%}
            { "@type": "Thing", "name": "Deity jewellery" },
            { "@type": "Thing", "name": "Hindu idol alankaram" },
            { "@type": "Thing", "name": "Idol size fit" }
          {%- endif -%}
          {%- if collection_deity_group != blank -%}
            ,{ "@type": "Thing", "name": {{ collection_deity_group | strip | json }} }
          {%- endif -%}
          {%- if collection_ornament_type != blank -%}
            ,{ "@type": "Thing", "name": {{ collection_ornament_type | strip | json }} }
          {%- endif -%}
        ],
        "mainEntity": { "@id": "{{ shop.url }}{{ collection.url }}#itemlist" },
        "isPartOf": { "@id": "https://www.goldencollections.com/#website" }
      },
      {
        "@type": "BreadcrumbList",
        "@id": "{{ shop.url }}{{ collection.url }}#breadcrumb",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{ shop.url }}"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": {{ schema_parent_label | json }},
            "item": "{{ shop.url }}{{ deity_collection_url }}"
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": {{ collection.title | json }},
            "item": "{{ shop.url }}{{ collection.url }}"
          }
        ]
      },
      {
        "@type": "ItemList",
        "@id": "{{ shop.url }}{{ collection.url }}#itemlist",
        "name": {{ collection.title | json }},
        "description": {{ collection_description | strip | json }},
        "numberOfItems": {{ collection.products_count }},
        "itemListElement": [
          {%- for product in collection.products limit: 30 -%}
            {%- liquid
              assign card_primary_deity_ref = product.metafields.custom.primary_deity_ref.value | default: product.metafields.custom.primary_deity.value
              assign card_primary_deity = card_primary_deity_ref.name.value | default: card_primary_deity_ref.name | default: product.metafields.custom.primary_deity.value | default: product.metafields.custom.primary_deity
              assign card_ornament_ref = product.metafields.custom.ornament_type_ref.value | default: product.metafields.custom.ornament_type.value
              assign card_ornament = card_ornament_ref.name.value | default: card_ornament_ref.name | default: product.metafields.custom.ornament_type.value | default: product.metafields.custom.ornament_type | default: product.type
              assign card_compatibility = product.metafields.custom.compatibility_class.value | default: product.metafields.custom.compatibility_class
              assign card_idol_min = product.metafields.custom.idol_height_min_in.value | default: product.metafields.custom.idol_height_min_in
              assign card_idol_max = product.metafields.custom.idol_height_max_in.value | default: product.metafields.custom.idol_height_max_in
              assign card_ornament_width = product.metafields.custom.ornament_width_in.value | default: product.metafields.custom.ornament_width_in
              assign card_ornament_height = product.metafields.custom.ornament_height_in.value | default: product.metafields.custom.ornament_height_in
              assign card_ornament_depth = product.metafields.custom.ornament_depth_in.value | default: product.metafields.custom.ornament_depth_in
              assign card_category = card_ornament | default: collection.title
              assign card_type_property_name = 'Ornament type'
              if faq_family == 'dance_crown'
                assign card_type_property_name = 'Performance accessory type'
              elsif faq_family == 'varalakshmi'
                assign card_type_property_name = 'Pooja idol type'
              elsif faq_family == 'banana_decor'
                assign card_type_property_name = 'Product type'
              endif
            -%}
            {%- capture card_idol_range -%}
              {%- if card_idol_min != blank and card_idol_max != blank -%}
                {{ card_idol_min }}-{{ card_idol_max }} inch idol
              {%- elsif card_idol_min != blank -%}
                {{ card_idol_min }} inch idol and above
              {%- elsif card_idol_max != blank -%}
                Up to {{ card_idol_max }} inch idol
              {%- endif -%}
            {%- endcapture -%}
            {%- capture card_measured_size -%}
              {%- if faq_family == 'necklace' -%}
                {%- if card_ornament_height != blank -%}Length {{ card_ornament_height }} in{%- endif -%}
                {%- if card_ornament_height != blank and card_ornament_width != blank -%}; {% endif -%}
                {%- if card_ornament_width != blank -%}Width {{ card_ornament_width }} in{%- endif -%}
              {%- else -%}
                {%- if card_ornament_width != blank -%}Width {{ card_ornament_width }} in{%- endif -%}
                {%- if card_ornament_width != blank and card_ornament_height != blank -%}; {% endif -%}
                {%- if card_ornament_height != blank -%}Height {{ card_ornament_height }} in{%- endif -%}
              {%- endif -%}
              {%- if card_ornament_depth != blank -%}
                {%- if card_ornament_width != blank or card_ornament_height != blank -%}; {% endif -%}
                Depth {{ card_ornament_depth }} in
              {%- endif -%}
            {%- endcapture -%}
            {
              "@type": "ListItem",
              "position": {{ forloop.index }},
              "url": "{{ shop.url }}{{ product.url }}",
              "item": {
                "@type": "Product",
                "@id": "{{ shop.url }}{{ product.url }}#product",
                "name": {{ product.title | json }},
                "url": "{{ shop.url }}{{ product.url }}",
                "image": "{{ product.featured_media | image_url: width: 900 | prepend: 'https:' }}",
                "category": {% if faq_family == 'dance_crown' %}"Bharatanatyam and Kuchipudi drama crown costume accessory"{% elsif faq_family == 'varalakshmi' %}"Varalakshmi Vratham idol or doll for pooja"{% else %}{{ card_category | strip | json }}{% endif %},
                "additionalProperty": [
                  { "@type": "PropertyValue", "name": {{ card_type_property_name | json }}, "value": {{ card_category | strip | json }} }
                  {%- if card_primary_deity != blank and faq_family != 'dance_crown' -%}
                  ,{ "@type": "PropertyValue", "name": "Primary deity", "value": {{ card_primary_deity | strip | json }} }
                  {%- endif -%}
                  {%- if card_compatibility != blank -%}
                  ,{ "@type": "PropertyValue", "name": {% if faq_family == 'dance_crown' %}"Performance use"{% else %}"Deity compatibility"{% endif %}, "value": {{ card_compatibility | strip | json }} }
                  {%- endif -%}
                  {%- if card_idol_range != blank and faq_family != 'dance_crown' -%}
                  ,{ "@type": "PropertyValue", "name": "Generally suitable for idol size", "value": {{ card_idol_range | strip | json }} }
                  {%- endif -%}
                  {%- if card_measured_size != blank -%}
                  ,{ "@type": "PropertyValue", "name": "Actual ornament measurement", "value": {{ card_measured_size | strip | json }} }
                  {%- endif -%}
                ],
                "offers": {
                  "@type": "Offer",
                  "priceCurrency": "{{ cart.currency.iso_code }}",
                  "price": "{{ product.price | money_without_currency | replace: ',', '' }}",
                  "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
                  "url": "{{ shop.url }}{{ product.url }}"
                }
              }
            }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ]
      }
      {%- comment -%}
        FAQPage schema is emitted by sections/ornament-collection-footer.liquid,
        where the matching FAQ is visible on the page.
      {%- endcomment -%}
    ]
  }
  </script>
{%- endif -%}
