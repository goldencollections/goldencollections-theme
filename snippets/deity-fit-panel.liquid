{%- comment -%}
  Deity product fit panel.
  Reads product metafields when available and falls back to safe customer-facing defaults.
{%- endcomment -%}

{%- liquid
  assign primary_deity_ref = product.metafields.custom.primary_deity_ref.value | default: product.metafields.custom.primary_deity.value
  assign primary_deity = primary_deity_ref.name.value | default: primary_deity_ref.name | default: product.metafields.custom.primary_deity.value | default: product.metafields.custom.primary_deity
  assign compatibility = product.metafields.custom.compatibility_class.value | default: product.metafields.custom.compatibility_class
  assign ornament_ref = product.metafields.custom.ornament_type_ref.value | default: product.metafields.custom.ornament_type.value
  assign ornament_type = ornament_ref.name.value | default: ornament_ref.name | default: product.metafields.custom.ornament_type.value | default: product.metafields.custom.ornament_type
  assign placement = product.metafields.custom.placement.value | default: product.metafields.custom.placement
  assign product_title_lc = product.title | downcase
  assign confidence = product.metafields.custom.size_confidence.value | default: product.metafields.custom.size_confidence
  assign idol_min = product.metafields.custom.idol_height_min_in.value | default: product.metafields.custom.idol_height_min_in
  assign idol_max = product.metafields.custom.idol_height_max_in.value | default: product.metafields.custom.idol_height_max_in
  assign ornament_width = product.metafields.custom.ornament_width_in.value | default: product.metafields.custom.ornament_width_in
  assign ornament_height = product.metafields.custom.ornament_height_in.value | default: product.metafields.custom.ornament_height_in
  assign ornament_depth = product.metafields.custom.ornament_depth_in.value | default: product.metafields.custom.ornament_depth_in
  assign crown_style = product.metafields.custom.crown_style.value | default: product.metafields.custom.crown_style
  assign crown_inner_width = product.metafields.custom.crown_inner_width_in.value | default: product.metafields.custom.crown_inner_width_in
  assign crown_outer_width = product.metafields.custom.crown_outer_width_in.value | default: product.metafields.custom.crown_outer_width_in
  assign crown_inner_circumference = product.metafields.custom.crown_inner_circumference_in.value | default: product.metafields.custom.crown_inner_circumference_in
  assign crown_arc_length = product.metafields.custom.crown_arc_length_in.value | default: product.metafields.custom.crown_arc_length_in
  assign material = product.metafields.custom.material.value | default: product.metafields.custom.material
  assign fit_notes = product.metafields.custom.fit_notes.value | default: product.metafields.custom.fit_notes
  assign regional_names_metafield = product.metafields.custom.regional_names
  assign regional_names = product.metafields.custom.regional_names.value | default: product.metafields.custom.regional_names
  assign regional_names_text = regional_names_metafield | metafield_text
  assign regional_names_manual_display = product.metafields.custom.regional_names_display.value | default: product.metafields.custom.regional_names_display
  assign regional_name_0 = regional_names_metafield.value[0]
  assign regional_name_1 = regional_names_metafield.value[1]
  assign regional_name_2 = regional_names_metafield.value[2]
  assign regional_name_3 = regional_names_metafield.value[3]
  assign regional_name_4 = regional_names_metafield.value[4]
  assign regional_name_5 = regional_names_metafield.value[5]
  assign regional_name_6 = regional_names_metafield.value[6]
  assign regional_name_7 = regional_names_metafield.value[7]

  if ornament_type == blank
    if product_title_lc contains 'crown' or product_title_lc contains 'mukut' or product_title_lc contains 'kireed' or product_title_lc contains 'kirita'
      assign ornament_type = 'Crown / Mukut / Kireedam'
    elsif product_title_lc contains 'haram'
      assign ornament_type = 'Haram'
    elsif product_title_lc contains 'vaddanam' or product_title_lc contains 'waist'
      assign ornament_type = 'Vaddanam / waist belt'
    elsif product_title_lc contains 'earring'
      assign ornament_type = 'Earrings'
    endif
  endif

  if placement == blank
    if ornament_type contains 'Crown'
      assign placement = 'Head'
    elsif ornament_type contains 'Haram'
      assign placement = 'Neck / chest'
    elsif ornament_type contains 'Vaddanam'
      assign placement = 'Waist'
    elsif ornament_type contains 'Earrings'
      assign placement = 'Ears'
    endif
  endif

  assign measured_size = ''
  if ornament_width != blank
    assign measured_size = 'W ' | append: ornament_width | append: ' in'
  endif
  if ornament_height != blank
    if measured_size != blank
      assign measured_size = measured_size | append: ' / '
    endif
    assign measured_size = measured_size | append: 'H ' | append: ornament_height | append: ' in'
  endif
  if ornament_depth != blank
    if measured_size != blank
      assign measured_size = measured_size | append: ' / '
    endif
    assign measured_size = measured_size | append: 'D ' | append: ornament_depth | append: ' in'
  endif

  assign crown_measurement = ''
  if crown_inner_width != blank
    assign crown_measurement = 'Inner W ' | append: crown_inner_width | append: ' in'
  elsif crown_outer_width != blank
    assign crown_measurement = 'Outer W ' | append: crown_outer_width | append: ' in'
  endif
  if crown_inner_circumference != blank
    if crown_measurement != blank
      assign crown_measurement = crown_measurement | append: ' / '
    endif
    assign crown_measurement = crown_measurement | append: 'Circ. ' | append: crown_inner_circumference | append: ' in'
  endif
  if crown_arc_length != blank
    if crown_measurement != blank
      assign crown_measurement = crown_measurement | append: ' / '
    endif
    assign crown_measurement = crown_measurement | append: 'Arc ' | append: crown_arc_length | append: ' in'
  endif
  assign is_crown_product = false
  if product_title_lc contains 'crown' or product_title_lc contains 'mukut' or product_title_lc contains 'kireed' or product_title_lc contains 'kirita' or ornament_type contains 'Crown' or ornament_type contains 'Mukut' or ornament_type contains 'Kireed'
    assign is_crown_product = true
  endif
-%}

{%- capture idol_range -%}
  {%- if idol_min != blank and idol_max != blank -%}
    {{ idol_min }}-{{ idol_max }} in
  {%- elsif idol_min != blank -%}
    {{ idol_min }} in and above
  {%- elsif idol_max != blank -%}
    Up to {{ idol_max }} in
  {%- else -%}
    Check measured images
  {%- endif -%}
{%- endcapture -%}

{%- capture suggested_for -%}
  {%- if primary_deity != blank and compatibility != blank -%}
    {{ primary_deity }} - {{ compatibility }}
  {%- elsif primary_deity != blank -%}
    {{ primary_deity }}
  {%- elsif compatibility != blank -%}
    {{ compatibility }}
  {%- else -%}
    Match by deity, placement and measured size
  {%- endif -%}
{%- endcapture -%}

{%- capture regional_names_display -%}
  {%- if regional_name_0 != blank -%}
    {{ regional_name_0 }}{% if regional_name_1 != blank %}, {{ regional_name_1 }}{% endif %}{% if regional_name_2 != blank %}, {{ regional_name_2 }}{% endif %}{% if regional_name_3 != blank %}, {{ regional_name_3 }}{% endif %}{% if regional_name_4 != blank %}, {{ regional_name_4 }}{% endif %}{% if regional_name_5 != blank %}, {{ regional_name_5 }}{% endif %}{% if regional_name_6 != blank %}, {{ regional_name_6 }}{% endif %}{% if regional_name_7 != blank %}, {{ regional_name_7 }}{% endif %}
  {%- endif -%}
{%- endcapture -%}

{%- if mode == 'compact' -%}
  <div class="gc-deity-fit-brief" id="deity-fit-summary">
    <div class="gc-deity-fit-brief__head">
      <span>Check fit before ordering</span>
      <div>
        <a href="/pages/how-to-measure-idol-for-deity-jewellery">Size guide</a>
        <a href="https://wa.me/917337294499?text={{ 'Hello Golden Collections, I need help checking deity jewellery size for ' | append: product.title | url_encode }}">
          Ask Anil
        </a>
      </div>
    </div>
    <dl class="gc-deity-fit-brief__grid">
      <div>
        <dt>Idol height fit</dt>
        <dd>{{ idol_range | strip }}</dd>
      </div>
      <div>
        <dt>Product measurement</dt>
        <dd>
          {%- if measured_size != blank -%}
            {{ measured_size }}
          {%- else -%}
            Select size below
          {%- endif -%}
        </dd>
      </div>
      <div>
        <dt>Ornament type</dt>
        <dd>{{ ornament_type | default: 'Deity ornament' }}</dd>
      </div>
      <div>
        <dt>Placement</dt>
        <dd>{{ placement | default: 'See product photos' }}</dd>
      </div>
      <div>
        <dt>Suggested for</dt>
        <dd>{{ suggested_for | strip }}</dd>
      </div>
    </dl>
    <p>
      Use the measuring tape photos and selected size before ordering. For crowns, compare head width or full circumference depending on crown style.
    </p>
  </div>
{%- else -%}
<div class="gc-deity-fit" id="deity-fit-panel">
  <div class="gc-deity-fit__badges" aria-label="Product fit summary">
    {%- if primary_deity != blank -%}
      <span>Made for {{ primary_deity }}</span>
    {%- endif -%}
    {%- if compatibility != blank -%}
      <span>{{ compatibility }}</span>
    {%- endif -%}
    <span>Quality checked</span>
  </div>

  <div class="gc-deity-fit__grid">
    <div>
      <span>Idol height fit</span>
      <strong>{{ idol_range | strip }}</strong>
    </div>
    <div>
      <span>Ornament type</span>
      <strong>{{ ornament_type | default: 'Check product details' }}</strong>
    </div>
    <div>
      <span>Actual ornament measurement</span>
      <strong>
        {%- if measured_size != blank -%}
          {{ measured_size }}
        {%- else -%}
          See measuring tape image
        {%- endif -%}
      </strong>
    </div>
    {%- if crown_measurement != blank or crown_style != blank -%}
      <div>
        <span>Crown fit check</span>
        <strong>
          {%- if crown_measurement != blank -%}
            {{ crown_measurement }}
          {%- else -%}
            {{ crown_style }}
          {%- endif -%}
        </strong>
      </div>
    {%- endif -%}
    <div>
      <span>Placement</span>
      <strong>{{ placement | default: 'Check product image' }}</strong>
    </div>
    {%- if material != blank -%}
      <div>
        <span>Material / plating</span>
        <strong>{{ material }}</strong>
      </div>
    {%- endif -%}
  </div>

  <p class="gc-deity-fit__note">
    {%- if fit_notes != blank -%}
      {{ fit_notes }}
    {%- else -%}
      Idol posture, head width, crown shape, and draping can affect fit. Use the selected size and measuring tape image before ordering.
    {%- endif -%}
  </p>

  <div class="gc-deity-fit__checklist" aria-label="Before ordering checklist">
    <strong>Before ordering, check</strong>
    <ul>
      <li>Generally suitable idol size is close to your idol height.</li>
      <li>Selected product measurement fits the area where it will sit.</li>
      <li>Placement and deity match how you plan to decorate the idol.</li>
    </ul>
  </div>

  <div class="gc-deity-fit__actions">
    <a href="/pages/how-to-measure-idol-for-deity-jewellery" class="gc-deity-fit__guide">
      Open size guide
    </a>
    <a href="/pages/how-golden-collections-checks-deity-jewellery-fit" class="gc-deity-fit__guide">
      See fit process
    </a>
    {%- if is_crown_product -%}
      <a href="/pages/deity-crown-mukut-kireedam-size-guide" class="gc-deity-fit__guide">
        Crown size guide
      </a>
    {%- endif -%}
    <a href="https://wa.me/917337294499?text={{ 'Hello Golden Collections, I need help checking deity jewellery size for ' | append: product.title | url_encode }}" class="gc-deity-fit__whatsapp">
      Ask Anil on WhatsApp
    </a>
    <span>Fit confidence: {{ confidence | default: 'Check product image' }}</span>
  </div>

  {%- if regional_names_manual_display != blank or regional_names_display != blank or regional_names != blank -%}
    <div class="gc-deity-fit__regional">
      <span>Also searched as:</span>
      <span class="gc-regional-list">
        {%- if regional_names_manual_display != blank -%}
          {{ regional_names_manual_display }}
        {%- elsif regional_names_metafield != blank -%}
          {{ regional_names_metafield | metafield_tag }}
        {%- else -%}
          {{ regional_names_text | default: regional_names }}
        {%- endif -%}
      </span>
    </div>
  {%- endif -%}
</div>
{%- endif -%}

<style>
  .gc-deity-fit-brief {
    border: 1px solid rgba(175, 129, 43, 0.24);
    border-radius: 8px;
    background: #fffaf0;
    padding: 1.2rem;
    margin: 1rem 0 1.2rem;
  }

  .gc-deity-fit-brief__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.9rem;
  }

  .gc-deity-fit-brief__head div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    justify-content: flex-end;
  }

  .gc-deity-fit-brief__head span {
    color: #20180f;
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .gc-deity-fit-brief__head a {
    color: #8f1f18;
    font-size: 1.2rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
  }

  .gc-deity-fit-brief__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem;
    margin: 0;
  }

  .gc-deity-fit-brief__grid div {
    border: 1px solid rgba(97, 65, 21, 0.12);
    border-radius: 6px;
    background: #ffffff;
    padding: 0.75rem;
  }

  .gc-deity-fit-brief dt {
    color: #756655;
    font-size: 1.05rem;
    line-height: 1.2;
    margin: 0 0 0.2rem;
  }

  .gc-deity-fit-brief dd {
    color: #21180d;
    font-size: 1.22rem;
    font-weight: 700;
    line-height: 1.2;
    margin: 0;
  }

  .gc-deity-fit-brief p {
    color: #564b3f;
    font-size: 1.22rem;
    line-height: 1.35;
    margin: 0.9rem 0 0;
  }

  .gc-deity-fit {
    border: 1px solid rgba(175, 129, 43, 0.25);
    border-radius: 8px;
    background: #fffbf2;
    padding: 1.6rem;
    margin: 1.4rem 0;
  }

  .gc-deity-fit__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 1.2rem;
  }

  .gc-deity-fit__badges span,
  .gc-deity-fit__actions span {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    border-radius: 999px;
    background: #f6ead0;
    color: #5e3d13;
    font-size: 1.2rem;
    line-height: 1.2;
    padding: 0.45rem 0.85rem;
  }

  .gc-deity-fit__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .gc-deity-fit__grid div {
    border: 1px solid rgba(97, 65, 21, 0.14);
    border-radius: 8px;
    background: #ffffff;
    padding: 1rem;
  }

  .gc-deity-fit__grid span {
    display: block;
    color: #7a6a58;
    font-size: 1.15rem;
    margin-bottom: 0.35rem;
  }

  .gc-deity-fit__grid strong {
    display: block;
    color: #21180d;
    font-size: 1.35rem;
    line-height: 1.25;
  }

  .gc-deity-fit__note,
  .gc-deity-fit__regional {
    color: #4f463c;
    font-size: 1.35rem;
    line-height: 1.45;
    margin: 1.2rem 0 0;
  }

  .gc-deity-fit__checklist {
    border: 1px solid rgba(31, 122, 77, 0.18);
    border-radius: 8px;
    background: #fff7e8;
    color: #5e3d13;
    margin-top: 1.2rem;
    padding: 1.1rem 1.2rem;
  }

  .gc-deity-fit__checklist strong {
    display: block;
    font-size: 1.35rem;
    line-height: 1.25;
    margin-bottom: 0.6rem;
  }

  .gc-deity-fit__checklist ul {
    margin: 0;
    padding-left: 1.8rem;
  }

  .gc-deity-fit__checklist li {
    font-size: 1.25rem;
    line-height: 1.4;
    margin: 0.25rem 0;
  }

  .gc-regional-list ul,
  .gc-regional-list ol {
    display: inline;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .gc-regional-list li {
    display: inline;
  }

  .gc-regional-list li:not(:last-child)::after {
    content: ', ';
  }

  .gc-deity-fit__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    align-items: center;
    margin-top: 1.2rem;
  }

  .gc-deity-fit__whatsapp {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    border-radius: 6px;
    background: #8f1f18;
    color: #ffffff;
    font-weight: 700;
    padding: 0.75rem 1.15rem;
    text-decoration: none;
  }

  .gc-deity-fit__guide {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    border: 1px solid rgba(151, 99, 16, 0.24);
    border-radius: 6px;
    background: #ffffff;
    color: #5e3d13;
    font-weight: 700;
    padding: 0.75rem 1.15rem;
    text-decoration: none;
  }

  @media screen and (max-width: 749px) {
    .gc-deity-fit-brief {
      padding: 1rem;
      margin: 0.85rem 0 1rem;
    }

    .gc-deity-fit-brief__grid {
      grid-template-columns: 1fr;
    }

    .gc-deity-fit {
      padding: 1.2rem;
      margin: 1rem 0;
    }

    .gc-deity-fit__grid {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .gc-deity-fit__whatsapp {
      width: 100%;
    }

    .gc-deity-fit__guide {
      width: 100%;
    }
  }
</style>
