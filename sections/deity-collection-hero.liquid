{%- liquid
  assign collection_intro = collection.metafields.custom.collection_intro.value | default: collection.metafields.custom.collection_intro | default: collection.metafields.custom.collection_intent.value | default: collection.metafields.custom.collection_intent
  assign intro = collection_intro | default: section.settings.intro | default: collection.description | strip_html
  assign display_title = collection.metafields.custom.display_title.value | default: collection.metafields.custom.display_title | default: collection.title
  assign shopping_path_label = collection.metafields.custom.shopping_path_label.value | default: collection.metafields.custom.shopping_path_label | default: display_title
  assign count_text = collection.products_count | append: ' products'
  assign deity_collection_url = collections['deity-jewelry'].url | default: routes.collections_url
  assign parent_collection_label = 'Deity Jewellery'
  assign collection_handle_lc = collection.handle | downcase
  assign collection_title_lc = collection.title | downcase
  assign is_performance_crown_collection = false
  if collection_handle_lc contains 'drama-dance-crowns' or collection_title_lc contains 'drama crown' or collection_title_lc contains 'dance crown'
    assign is_performance_crown_collection = true
    assign parent_collection_label = 'Bharatanatyam Jewellery'
    assign deity_collection_url = collections['bharatanatyam-jewellery'].url | default: routes.collections_url
  endif

  assign collection_deity_group_ref = collection.metafields.custom.primary_deity_ref.value | default: collection.metafields.custom.deity_group.value
  assign collection_deity_group = collection_deity_group_ref.name.value | default: collection_deity_group_ref.name | default: collection.metafields.custom.deity_group.value | default: collection.metafields.custom.deity_group
  assign collection_ornament_type_ref = collection.metafields.custom.ornament_type_ref.value | default: collection.metafields.custom.ornament_type.value
  assign collection_ornament_type = collection_ornament_type_ref.name.value | default: collection_ornament_type_ref.name | default: collection.metafields.custom.ornament_type.value | default: collection.metafields.custom.ornament_type
  assign collection_role = collection.metafields.custom.collection_role.value | default: collection.metafields.custom.collection_role | downcase | strip
  assign deity_first_enabled = collection.metafields.custom.deity_first_enabled.value | default: collection.metafields.custom.deity_first_enabled
  assign template_mode = section.settings.template_mode
  if template_mode == 'auto' or template_mode == blank
    if collection_role == 'ornament_first' or collection_role == 'deity_ornament' or collection_role == 'accessory'
      assign template_mode = 'ornament'
    elsif collection_role == 'deity_landing' or collection_role == 'festival' or collection_role == 'shop_by_deity_root' or deity_first_enabled == true or deity_first_enabled == 'true'
      assign template_mode = 'deity_first'
    elsif collection_ornament_type != blank and collection_deity_group == blank
      assign template_mode = 'ornament'
    else
      assign template_mode = 'deity_first'
    endif
  endif

  assign size_profile_ref = collection.metafields.custom.size_profile_ref.value | default: collection.metafields.custom.size_profile_ref
  assign size_profile_label = size_profile_ref.label.value | default: size_profile_ref.label
  assign size_profile_min = size_profile_ref.idol_height_min_in.value | default: size_profile_ref.idol_height_min_in
  assign size_profile_max = size_profile_ref.idol_height_max_in.value | default: size_profile_ref.idol_height_max_in

  assign direct_subcollections = collection.metafields.custom.subcollections.value
  assign related_collections = collection.metafields.custom.related_collection_refs.value
  assign deity_featured_collections = collection_deity_group_ref.featured_collections.value
  assign has_direct_subcollections = false
  assign has_related_collections = false
  assign has_deity_featured_collections = false
  if direct_subcollections != blank and direct_subcollections.size > 0
    assign has_direct_subcollections = true
  elsif related_collections != blank and related_collections.size > 0
    assign has_related_collections = true
  elsif deity_featured_collections != blank and deity_featured_collections.size > 0
    assign has_deity_featured_collections = true
  endif

  assign fallback_crowns = collections['deity-crowns']
  assign fallback_stone_crowns = collections['deity-stone-crowns']
  assign fallback_long_harams = collections['deity-long-harams']
  assign fallback_short_harams = collections['deity-short-harams']
  assign fallback_earrings = collections['deity-earrings-for-god-idols-statues']
  assign fallback_accessories = collections['deity-accessories-nose-rings-mustache-weapons-taira']
  assign fallback_pustal = collections['deity-god-pustal-tadu-thali-kasulaperu']
-%}

{%- capture summary_text -%}
  {%- if template_mode == 'ornament' and collection_ornament_type != blank -%}
    Shop {{ collection_ornament_type }} by deity compatibility, idol size and measured fit.
  {%- elsif template_mode == 'ornament' -%}
    Shop this ornament category by deity compatibility, idol size and measured fit.
  {%- elsif collection_deity_group != blank and collection_ornament_type != blank -%}
    {{ collection_ornament_type }} for {{ collection_deity_group }}, organized by idol size and fit.
  {%- elsif collection_deity_group != blank -%}
    Shop {{ collection_deity_group }} alankaram by ornament type and idol size.
  {%- elsif collection_ornament_type != blank -%}
    Shop {{ collection_ornament_type }} by deity, placement, and idol size.
  {%- else -%}
    Shop by deity, ornament type, and idol size.
  {%- endif -%}
{%- endcapture -%}

{%- capture default_size_text -%}
  {%- if size_profile_label != blank -%}
    {{ size_profile_label }}
  {%- elsif size_profile_min != blank and size_profile_max != blank -%}
    {{ size_profile_min }}-{{ size_profile_max }} in idols
  {%- elsif size_profile_min != blank -%}
    {{ size_profile_min }} in and above
  {%- elsif size_profile_max != blank -%}
    Up to {{ size_profile_max }} in idols
  {%- else -%}
    Match idol height to each product's measured fit notes.
  {%- endif -%}
{%- endcapture -%}

<section class="gc-deity-collection-hero gc-deity-collection-hero--{{ template_mode }} color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    <nav class="gc-deity-collection-hero__breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span>/</span>
      <a href="{{ deity_collection_url }}">{{ parent_collection_label }}</a>
      <span>/</span>
      <span>{{ collection.title }}</span>
    </nav>

    <div class="gc-deity-collection-hero__layout">
      <div class="gc-deity-collection-hero__copy">
        <h1>{{ display_title }}</h1>
        {%- if intro != blank and template_mode != 'ornament' -%}
          <p class="gc-deity-collection-hero__intro">
            {{ intro | strip_html | truncate: 220 }}
          </p>
        {%- endif -%}
      </div>
    </div>

    {%- if template_mode == 'ornament' -%}
      {%- if has_direct_subcollections or has_related_collections -%}
        <div class="gc-ornament-subcollections" aria-labelledby="gc-ornament-subcollections-heading">
          <h2 id="gc-ornament-subcollections-heading" class="visually-hidden">Collection types</h2>
          <ul class="gc-ornament-subcollections__list subcollection-nav list-unstyled" role="list">
            {%- if has_direct_subcollections -%}
              {%- for nav_collection in direct_subcollections limit: 8 -%}
                {%- if nav_collection != blank -%}
                  {%- liquid
                    assign nav_title = nav_collection.metafields.custom.display_title.value | default: nav_collection.metafields.custom.display_title | default: nav_collection.title
                    assign nav_image = nav_collection.featured_image | default: nav_collection.products.first.featured_media.preview_image
                    assign is_current = false
                    if nav_collection.handle == collection.handle
                      assign is_current = true
                    endif
                  -%}
                  {% render 'category-circle-nav', title: nav_title, url: nav_collection.url, image: nav_image, is_current: is_current %}
                {%- endif -%}
              {%- endfor -%}
            {%- else -%}
              {%- for nav_collection in related_collections limit: 8 -%}
                {%- if nav_collection != blank -%}
                  {%- liquid
                    assign nav_title = nav_collection.metafields.custom.display_title.value | default: nav_collection.metafields.custom.display_title | default: nav_collection.title
                    assign nav_image = nav_collection.featured_image | default: nav_collection.products.first.featured_media.preview_image
                    assign is_current = false
                    if nav_collection.handle == collection.handle
                      assign is_current = true
                    endif
                  -%}
                  {% render 'category-circle-nav', title: nav_title, url: nav_collection.url, image: nav_image, is_current: is_current %}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          </ul>
        </div>
      {%- endif -%}

    {%- else -%}
      <div class="gc-deity-landing-paths" aria-labelledby="gc-deity-path-heading">
        <h2 id="gc-deity-path-heading" class="visually-hidden">{{ section.settings.path_heading | default: 'Choose ornament path' }}</h2>
        <ul class="gc-deity-landing-paths__list subcollection-nav list-unstyled" role="list">
          {%- if has_direct_subcollections -%}
            {%- for nav_collection in direct_subcollections limit: 10 -%}
              {%- if nav_collection != blank -%}
                {%- liquid
                  assign nav_title = nav_collection.metafields.custom.display_title.value | default: nav_collection.metafields.custom.display_title | default: nav_collection.title
                  assign nav_image = nav_collection.featured_image | default: nav_collection.products.first.featured_media.preview_image
                  assign is_current = false
                  if nav_collection.handle == collection.handle
                    assign is_current = true
                  endif
                -%}
                {% render 'category-circle-nav', title: nav_title, url: nav_collection.url, image: nav_image, is_current: is_current %}
              {%- endif -%}
            {%- endfor -%}
          {%- elsif has_related_collections -%}
            {%- for nav_collection in related_collections limit: 10 -%}
              {%- if nav_collection != blank -%}
                {%- liquid
                  assign nav_title = nav_collection.metafields.custom.display_title.value | default: nav_collection.metafields.custom.display_title | default: nav_collection.title
                  assign nav_image = nav_collection.featured_image | default: nav_collection.products.first.featured_media.preview_image
                  assign is_current = false
                  if nav_collection.handle == collection.handle
                    assign is_current = true
                  endif
                -%}
                {% render 'category-circle-nav', title: nav_title, url: nav_collection.url, image: nav_image, is_current: is_current %}
              {%- endif -%}
            {%- endfor -%}
          {%- elsif has_deity_featured_collections -%}
            {%- for nav_collection in deity_featured_collections limit: 10 -%}
              {%- if nav_collection != blank -%}
                {%- liquid
                  assign nav_title = nav_collection.metafields.custom.display_title.value | default: nav_collection.metafields.custom.display_title | default: nav_collection.title
                  assign nav_image = nav_collection.featured_image | default: nav_collection.products.first.featured_media.preview_image
                  assign is_current = false
                  if nav_collection.handle == collection.handle
                    assign is_current = true
                  endif
                -%}
                {% render 'category-circle-nav', title: nav_title, url: nav_collection.url, image: nav_image, is_current: is_current %}
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            {%- liquid
              assign ornament_filter = blank
              assign crown_url = blank
              assign short_haram_url = blank
              assign long_haram_url = blank
              assign earrings_url = blank
              assign accessories_url = blank

              for filter in collection.filters
                assign filter_label = filter.label | downcase
                if filter_label contains 'product type' or filter_label contains 'ornament'
                  assign ornament_filter = filter
                  break
                endif
              endfor

              if ornament_filter != blank
                for value in ornament_filter.values
                  assign value_label = value.label | downcase
                  assign is_crown = false
                  assign is_short_haram = false
                  assign is_long_haram = false
                  assign is_earrings = false
                  assign is_accessories = false
                  if value_label contains 'crown' or value_label contains 'mukut' or value_label contains 'kireed'
                    assign is_crown = true
                  endif
                  if value_label contains 'short'
                    if value_label contains 'haram' or value_label contains 'necklace'
                      assign is_short_haram = true
                    endif
                  endif
                  if value_label contains 'long'
                    if value_label contains 'haram' or value_label contains 'necklace'
                      assign is_long_haram = true
                    endif
                  endif
                  if value_label contains 'earring' or value_label contains 'jimikki'
                    assign is_earrings = true
                  endif
                  if value_label contains 'accessor' or value_label contains 'weapon' or value_label contains 'tilak' or value_label contains 'nose'
                    assign is_accessories = true
                  endif

                  if crown_url == blank and is_crown
                    assign crown_url = value.url_to_add
                  elsif short_haram_url == blank and is_short_haram
                    assign short_haram_url = value.url_to_add
                  elsif long_haram_url == blank and is_long_haram
                    assign long_haram_url = value.url_to_add
                  elsif earrings_url == blank and is_earrings
                    assign earrings_url = value.url_to_add
                  elsif accessories_url == blank and is_accessories
                    assign accessories_url = value.url_to_add
                  endif
                endfor
              endif

              if ornament_filter == blank
                assign crown_url = fallback_crowns.url
                assign short_haram_url = fallback_short_harams.url
                assign long_haram_url = fallback_long_harams.url
                assign earrings_url = fallback_earrings.url
                assign accessories_url = fallback_accessories.url
              endif
            -%}
            {%- if crown_url != blank -%}
              {% render 'category-circle-nav', title: 'Crowns', url: crown_url, image: fallback_crowns.featured_image %}
            {%- endif -%}
            {%- if short_haram_url != blank -%}
              {% render 'category-circle-nav', title: 'Short Necklaces', url: short_haram_url, image: fallback_short_harams.featured_image %}
            {%- endif -%}
            {%- if long_haram_url != blank -%}
              {% render 'category-circle-nav', title: 'Long Harams', url: long_haram_url, image: fallback_long_harams.featured_image %}
            {%- endif -%}
            {%- if earrings_url != blank -%}
              {% render 'category-circle-nav', title: 'Earrings', url: earrings_url, image: fallback_earrings.featured_image %}
            {%- endif -%}
            {%- if accessories_url != blank -%}
              {% render 'category-circle-nav', title: 'Accessories', url: accessories_url, image: fallback_accessories.featured_image %}
            {%- endif -%}
          {%- endif -%}
        </ul>
      </div>
    {%- endif -%}

  </div>
</section>

<script>
  (() => {
    const section = document.currentScript.previousElementSibling;
    if (!section) return;
    const heightForm = section.querySelector('[data-gc-idol-size-form]');
    if (heightForm) {
      const heightSelect = heightForm.querySelector('[name="idolHeight"]');
      try {
        const savedHeight = window.localStorage.getItem('gc-deity-idol-height');
        if (savedHeight && heightSelect) heightSelect.value = savedHeight;
      } catch (error) {
        // Ignore private-mode storage failures; the selector still works as navigation.
      }
      heightForm.addEventListener('submit', (event) => {
        event.preventDefault();
        if (heightSelect && heightSelect.value) {
          try {
            window.localStorage.setItem('gc-deity-idol-height', heightSelect.value);
          } catch (error) {}
        }
        const target = document.getElementById('ProductGridContainer') || document.getElementById('product-grid');
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }
    if (!section.classList.contains('gc-deity-collection-hero--ornament')) return;
    const form = section.querySelector('[data-gc-fit-form]');
    const summary = section.querySelector('[data-gc-fit-summary]');
    const values = section.querySelector('[data-gc-fit-summary-values]');
    const edit = section.querySelector('[data-gc-fit-edit]');
    const render = () => {
      if (!summary || !values) return;
      let saved = {};
      try {
        saved = JSON.parse(window.localStorage.getItem('gc-deity-fit') || '{}');
      } catch (error) {
        saved = {};
      }
      const parts = [saved.idolHeight, saved.headWidth && `${saved.headWidth} head`].filter(Boolean);
      if (!parts.length) return;
      values.textContent = parts.join(' - ');
      summary.hidden = false;
    };
    if (form) {
      form.addEventListener('submit', (event) => {
        event.preventDefault();
        window.localStorage.setItem('gc-deity-fit', JSON.stringify(Object.fromEntries(new FormData(form).entries())));
        render();
        const target = document.getElementById('ProductGridContainer') || document.getElementById('product-grid');
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }
    if (edit && form) edit.addEventListener('click', () => form.scrollIntoView({ behavior: 'smooth', block: 'center' }));
    render();
  })();
</script>

