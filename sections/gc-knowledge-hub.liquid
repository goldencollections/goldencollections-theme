    margin: 0;
    max-width: 880px;
  }

  .gc-knowledge h2 {
    color: #1f170d;
    font-size: clamp(2.4rem, 3vw, 3.6rem);
    line-height: 1.08;
    margin: 0;
  }

  .gc-knowledge p,
  .gc-knowledge li,
  .gc-knowledge span {
    color: #4e4438;
    font-size: 1.18rem;
    line-height: 1.5;
  }

  .gc-knowledge__intro {
    font-size: 1.35rem;
    margin: 0;
    max-width: 820px;
  }

  .gc-knowledge .gc-knowledge__intro {
    color: #f5ede0;
  }

  .gc-knowledge__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.4rem;
  }

  .gc-knowledge__actions a {
    align-items: center;
    background: #8b1c1c;
    border: 1px solid #8b1c1c;
