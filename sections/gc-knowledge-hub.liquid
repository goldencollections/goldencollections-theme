    width: 100%;
  }

  .gc-knowledge__proof-wrap {
    background: #241508;
  }

  .gc-knowledge__proof {
    display: grid;
    gap: 0;
  }

  .gc-knowledge__proof article {
    border-left: 3px solid #c9972a;
    padding: 1.1rem 1rem;
  }

  .gc-knowledge__proof strong {
    color: #f5ede0;
    display: block;
    font-size: 1.35rem;
