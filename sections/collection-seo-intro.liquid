{%- liquid
  assign intro = collection.metafields.custom.collection_intro.value | default: collection.metafields.custom.collection_intro | default: collection.description
-%}

{%- if intro != blank -%}
  <section class="gc-collection-intro color-{{ section.settings.color_scheme }}">
    <div class="page-width">
      <div class="gc-collection-intro__body rte">
        {{ intro }}
      </div>
    </div>
  </section>
{%- endif -%}

<style>
  .gc-collection-intro {
    background: #fff8ea;
    color: #3b2a18;
    padding: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px 0 {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .gc-collection-intro__body {
    font-size: 1.34rem;
    line-height: 1.55;
    margin-inline: auto;
    max-width: 82rem;
    text-align: center;
  }

  .gc-collection-intro__body p {
    margin: 0;
  }

  .gc-collection-intro__body p + p {
    margin-top: 0.9rem;
  }

  @media screen and (min-width: 750px) {
    .gc-collection-intro {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .gc-collection-intro__body {
      font-size: 1.48rem;
    }
  }
</style>

{% schema %}
{
  "name": "Collection SEO intro",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Collection SEO intro"
    }
  ]
}
{% endschema %}
