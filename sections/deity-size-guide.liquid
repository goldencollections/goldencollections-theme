</style>

{% schema %}
{
  "name": "Deity size guide",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Deity jewellery size guide"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How to measure your deity idol"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Use this guide to choose crowns, harams, vaddanam, earrings and alankaram accessories with better fit confidence."
    },
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "WhatsApp number with country code",
      "default": "917337294499"
    }
  ],
  "presets": [
    {
      "name": "Deity size guide"
    }
  ]
}
{% endschema %}
