    padding: 1rem;
  }

  .gc-size-guide__quick article {
    display: grid;
    gap: 0.25rem;
  }

  .gc-size-guide__quick strong {
    color: #7f1f19;
    font-size: 1.22rem;
  }

  .gc-size-guide__quick span,
  .gc-size-guide p,
  .gc-size-guide li {
    color: #4f463c;
    font-size: 1.2rem;
    line-height: 1.42;
  }

  .gc-size-guide__nav {
    display: flex;
    gap: 0.55rem;
    margin: 0 -1.5rem 1.4rem;
    overflow-x: auto;
    padding: 0 1.5rem 0.4rem;
  }

  .gc-size-guide__nav a {
