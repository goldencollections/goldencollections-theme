    padding: 0.6rem 0.85rem;
    text-decoration: none;
  }

  .gc-size-guide__section {
    border-top: 1px solid rgba(151, 99, 16, 0.16);
    padding: 1.5rem 0;
  }

  .gc-size-guide__section-head {
    margin-bottom: 1rem;
  }

  .gc-size-guide h2 {
    font-size: 2.4rem;
    line-height: 1.12;
    max-width: 880px;
  }

  .gc-size-guide h3 {
    font-size: 1.85rem;
    line-height: 1.15;
  }

  .gc-size-guide__measure-card {
    display: grid;
    gap: 0.9rem;
  }

  .gc-size-guide__diagram {
