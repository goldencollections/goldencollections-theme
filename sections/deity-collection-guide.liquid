{%- liquid
  assign collection_handle = collection.handle | downcase
  assign collection_title = collection.title | downcase
  assign family_menu_handle = collection.metafields.custom.parent_menu_handles.value | default: ''
  assign family_menu_handle = family_menu_handle | downcase | strip | split: ',' | first | strip
  assign faq_family_metafield = collection.metafields.custom.faq_family.value | default: collection.metafields.custom.faq_family
  assign collection_deity_group_ref = collection.metafields.custom.primary_deity_ref.value | default: collection.metafields.custom.deity_group.value
  assign collection_deity_group = collection_deity_group_ref.name.value | default: collection_deity_group_ref.name | default: collection.metafields.custom.deity_group.value | default: collection.metafields.custom.deity_group
  assign collection_ornament_type_ref = collection.metafields.custom.ornament_type_ref.value | default: collection.metafields.custom.ornament_type.value
  assign collection_ornament_type = collection_ornament_type_ref.name.value | default: collection_ornament_type_ref.name | default: collection.metafields.custom.ornament_type.value | default: collection.metafields.custom.ornament_type
  assign ornament_placement = collection_ornament_type_ref.placement.value | default: collection_ornament_type_ref.placement
  assign ornament_fit_notes = collection_ornament_type_ref.fit_notes.value | default: collection_ornament_type_ref.fit_notes
  assign size_fit_intro = collection.metafields.custom.size_fit_intro.value | default: collection.metafields.custom.size_fit_intro | default: collection.metafields.custom.size_guide_copy.value | default: collection.metafields.custom.size_guide_copy
  assign guide_body = size_fit_intro | default: section.settings.body

  assign size_profile_ref = collection.metafields.custom.size_profile_ref.value | default: collection.metafields.custom.size_profile_ref
  assign size_profile_label = size_profile_ref.label.value | default: size_profile_ref.label
  assign size_profile_min = size_profile_ref.idol_height_min_in.value | default: size_profile_ref.idol_height_min_in
  assign size_profile_max = size_profile_ref.idol_height_max_in.value | default: size_profile_ref.idol_height_max_in
  assign size_profile_fit_notes = size_profile_ref.fit_notes.value | default: size_profile_ref.fit_notes
  assign size_profile_confidence = size_profile_ref.confidence.value | default: size_profile_ref.confidence
  assign crown_standard_ref = collection.metafields.custom.crown_size_standard_ref.value | default: collection.metafields.custom.crown_size_standard_ref
  assign crown_standard_label = crown_standard_ref.label.value | default: crown_standard_ref.label
  assign crown_head_min = crown_standard_ref.head_width_min_in.value | default: crown_standard_ref.head_width_min_in
  assign crown_head_max = crown_standard_ref.head_width_max_in.value | default: crown_standard_ref.head_width_max_in
  assign crown_fit_caveats = crown_standard_ref.fit_caveats.value | default: crown_standard_ref.fit_caveats

  assign regional_keyword_list = collection.metafields.custom.regional_keyword_cluster.value
  assign regional_keyword_text = collection.metafields.custom.regional_keyword_cluster | metafield_text
  assign deity_regional_names = collection_deity_group_ref.regional_names.value
  assign deity_aliases = collection_deity_group_ref.aliases.value
  assign ornament_aliases = collection_ornament_type_ref.aliases.value
  assign has_regional_terms = false
  if regional_keyword_list != blank or regional_keyword_text != blank or deity_regional_names != blank or deity_aliases != blank or ornament_aliases != blank
    assign has_regional_terms = true
  endif

  assign setup_collections = collection.metafields.custom.related_collection_refs.value
  assign has_setup_collections = false
  if setup_collections != blank and setup_collections.size > 0
    assign has_setup_collections = true
  endif
  assign faq_family_hint = faq_family_metafield | downcase | strip
  assign collection_role = collection.metafields.custom.collection_role.value | default: collection.metafields.custom.collection_role | downcase | strip
  assign template_mode = section.settings.template_mode | default: 'auto'
  if template_mode == 'auto'
    if collection_role == 'ornament_first' or collection_role == 'deity_ornament' or collection_role == 'accessory'
      assign template_mode = 'ornament'
    elsif collection_ornament_type != blank and collection_deity_group == blank
      assign template_mode = 'ornament'
    elsif faq_family_hint contains 'crown' or faq_family_hint contains 'necklace' or faq_family_hint contains 'haram' or faq_family_hint contains 'waist' or faq_family_hint contains 'accessory'
      assign template_mode = 'ornament'
    else
      assign template_mode = 'deity_first'
    endif
  endif
  assign bundle_collection = collections['varalakshmi-deity-jewellery']
  assign deity_root_collection = collections['deity-jewelry']
  assign crown_collection = collections['deity-crowns']
  assign haram_collection = collections['deity-long-harams']
  assign measure_url = '/pages/how-to-measure-idol-for-deity-jewellery'
  assign fit_process_url = '/pages/how-golden-collections-checks-deity-jewellery-fit'
  assign proof_hub_url = '/pages/temple-alankaram-proof'
  assign varalakshmi_examples_url = '/pages/varalakshmi-alankaram-examples'
  assign whatsapp_fit_text = 'Hello Golden Collections, I need Anil help choosing deity jewellery size for ' | append: collection.title
  assign whatsapp_fit_encoded = whatsapp_fit_text | url_encode
  assign whatsapp_fit_url = 'https://wa.me/917337294499?text=' | append: whatsapp_fit_encoded

  assign faq_family_source = faq_family_metafield
  if faq_family_source == blank
    assign faq_family_source = collection_deity_group | append: ' ' | append: collection_ornament_type
  endif
  assign faq_family_source = faq_family_source | downcase | strip
  assign faq_family = ''

  if faq_family_source contains 'varalakshmi' or faq_family_source contains 'vara lakshmi' or faq_family_source contains 'vara-lakshmi' or faq_family_source contains 'lakshmi'
    assign faq_family = 'varalakshmi'
  elsif faq_family_source contains 'decor' or faq_family_source contains 'decoration' or faq_family_source contains 'arch' or faq_family_source contains 'prabhavali' or faq_family_source contains 'stand' or faq_family_source contains 'asana'
    assign faq_family = 'decor'
  elsif faq_family_source contains 'vishnu' or faq_family_source contains 'perumal' or faq_family_source contains 'balaji' or faq_family_source contains 'venkateswara' or faq_family_source contains 'shankh' or faq_family_source contains 'chakra'
    assign faq_family = 'vishnu'
  elsif faq_family_source contains 'crown' or faq_family_source contains 'mukut' or faq_family_source contains 'kireed'
    assign faq_family = 'crown'
  elsif faq_family_source contains 'necklace' or faq_family_source contains 'haram' or faq_family_source contains 'pustal' or faq_family_source contains 'pendant'
    assign faq_family = 'necklace'
  elsif faq_family_source contains 'waist' or faq_family_source contains 'vaddanam' or faq_family_source contains 'oddiyanam'
    assign faq_family = 'waist'
  elsif faq_family_source contains 'accessory' or faq_family_source contains 'earring' or faq_family_source contains 'eyes' or faq_family_source contains 'nose' or faq_family_source contains 'bindi' or faq_family_source contains 'tilak' or faq_family_source contains 'thiruman' or faq_family_source contains 'taira' or faq_family_source contains 'weapon' or faq_family_source contains 'hands' or faq_family_source contains 'legs'
    assign faq_family = 'accessory'
  endif

  if faq_family == blank
    if collection_handle contains 'varalakshmi' or collection_handle contains 'vara-lakshmi' or collection_handle contains 'vagamalai' or collection_handle contains 'hands-legs-for-varalakshmi' or collection_title contains 'varalakshmi' or collection_title contains 'varamahalakshmi' or family_menu_handle contains 'varalakshmi'
      assign faq_family = 'varalakshmi'
    elsif collection_handle contains 'banana' or collection_handle contains 'lotus' or collection_handle contains 'stand' or collection_handle contains 'asana' or collection_handle contains 'sanctum' or collection_handle contains 'singhasan' or collection_handle contains 'cushions'
      assign faq_family = 'decor'
    elsif collection_handle contains 'shankh' or collection_handle contains 'chakra' or collection_handle contains 'vishnu' or collection_handle contains 'perumal' or family_menu_handle contains 'vishnu'
      assign faq_family = 'vishnu'
    elsif collection_handle contains 'crown' or collection_handle contains 'mukut' or collection_title contains 'crown' or collection_title contains 'mukut'
      assign faq_family = 'crown'
    elsif collection_handle contains 'necklace' or collection_handle contains 'haram' or collection_handle contains 'pustal' or collection_handle contains 'pendant' or collection_title contains 'necklace' or collection_title contains 'haram'
      assign faq_family = 'necklace'
    elsif collection_handle contains 'waist' or collection_handle contains 'vaddanam' or collection_title contains 'waist' or collection_title contains 'vaddanam'
      assign faq_family = 'waist'
    elsif collection_handle contains 'earring' or collection_handle contains 'eyes' or collection_handle contains 'nose' or collection_handle contains 'bindi' or collection_handle contains 'tilak' or collection_handle contains 'thiruman' or collection_handle contains 'taira' or collection_handle contains 'mustache' or collection_handle contains 'weapons' or collection_handle contains 'accessories'
      assign faq_family = 'accessory'
    endif
  endif

  if faq_family == blank
    assign faq_family = 'amman'
  endif

  assign dynamic_faq_heading = section.settings.faq_heading
  case faq_family
    when 'varalakshmi'
      assign dynamic_faq_heading = 'Varalakshmi alankaram size FAQ'
    when 'vishnu'
      assign dynamic_faq_heading = 'Vishnu and Perumal alankaram FAQ'
    when 'crown'
      assign dynamic_faq_heading = 'Deity crown and mukut size FAQ'
    when 'necklace'
      assign dynamic_faq_heading = 'Deity necklace and haram size FAQ'
    when 'waist'
      assign dynamic_faq_heading = 'Deity waist belt and vaddanam FAQ'
    when 'accessory'
      assign dynamic_faq_heading = 'Deity accessory fit FAQ'
    when 'decor'
      assign dynamic_faq_heading = 'Deity decoration size FAQ'
  endcase

  assign guide_eyebrow = section.settings.eyebrow
  assign guide_heading = section.settings.heading
  assign bundle_label = 'Bundles and full setup'
  assign bundle_heading = section.settings.bundle_heading | default: 'Complete the alankaram lower on the page'
  assign bundle_body = section.settings.bundle_body | default: 'After choosing the right fit, use these paths for full deity setup, festival bundles or matching ornament families.'
  if template_mode == 'ornament'
    assign guide_eyebrow = 'Crown sizing guide'
    if faq_family != 'crown'
      assign guide_eyebrow = 'Ornament fit guide'
    endif
    assign guide_heading = 'Measure right, buy right'
    assign bundle_label = 'Related collections'
    assign bundle_heading = 'Continue after the fit is clear'
    assign bundle_body = 'Move to necklaces, vaddanam, harams or matching accessories only after the current ornament size is likely to fit.'
  endif
-%}

{%- capture size_profile_text -%}
  {%- if size_profile_label != blank -%}
    {{ size_profile_label }}
  {%- elsif size_profile_min != blank and size_profile_max != blank -%}
    {{ size_profile_min }}-{{ size_profile_max }} inch idols
  {%- elsif size_profile_min != blank -%}
    {{ size_profile_min }} inch idols and above
  {%- elsif size_profile_max != blank -%}
    Up to {{ size_profile_max }} inch idols
  {%- else -%}
    Use the idol height shown on each product.
  {%- endif -%}
{%- endcapture -%}

{%- capture crown_standard_text -%}
  {%- if crown_standard_label != blank -%}
    {{ crown_standard_label }}
  {%- elsif crown_head_min != blank and crown_head_max != blank -%}
    Head width {{ crown_head_min }}-{{ crown_head_max }} in
  {%- elsif crown_head_min != blank -%}
    Head width from {{ crown_head_min }} in
  {%- elsif crown_head_max != blank -%}
    Head width up to {{ crown_head_max }} in
  {%- else -%}
    Compare crown width and height with the measuring tape image.
  {%- endif -%}
{%- endcapture -%}

<section class="gc-deity-guide gc-deity-guide--{{ template_mode }}" id="gc-deity-size-guide">
  <div class="page-width">
    <div class="gc-deity-guide__layout">
      <div class="gc-deity-guide__main">
        <p class="gc-deity-guide__eyebrow">{{ guide_eyebrow }}</p>
        <h2>{{ guide_heading }}</h2>
        <p>{{ guide_body }}</p>
      </div>

      <div class="gc-deity-guide__panel" aria-label="Collection size guidance">
        <div class="gc-deity-guide__panel-head">
          <span>Size guidance</span>
          <strong>{{ size_profile_text | strip }}</strong>
        </div>
        <dl class="gc-deity-guide__facts">
          <div>
            <dt>Made for</dt>
            <dd>{{ collection_deity_group | default: 'Match the deity shown on each product' }}</dd>
          </div>
          <div>
            <dt>Ornament path</dt>
            <dd>{{ collection_ornament_type | default: 'Choose by placement and measured size' }}</dd>
          </div>
          <div>
            <dt>Placement</dt>
            <dd>{{ ornament_placement | default: 'Head, neck, chest, waist or decoration area' }}</dd>
          </div>
          <div>
            <dt>Crown check</dt>
            <dd>{{ crown_standard_text | strip }}</dd>
          </div>
        </dl>
        <p>
          {%- if size_profile_fit_notes != blank -%}
            {{ size_profile_fit_notes }}
          {%- elsif ornament_fit_notes != blank -%}
            {{ ornament_fit_notes }}
          {%- elsif crown_fit_caveats != blank -%}
            {{ crown_fit_caveats }}
          {%- else -%}
            Idol posture, head width, crown shape and cloth draping can change fit. Use product measurements before ordering.
          {%- endif -%}
        </p>
        {%- if size_profile_confidence != blank -%}
          <span class="gc-deity-guide__confidence">Fit confidence: {{ size_profile_confidence }}</span>
        {%- endif -%}
      </div>
    </div>

    <div class="gc-deity-guide__steps" aria-label="How to choose deity jewellery size">
      <div>
        <span>1</span>
        <strong>
          {%- if template_mode == 'ornament' -%}
            Start with the placement measurement
          {%- else -%}
            Start with idol height
          {%- endif -%}
        </strong>
        <p>
          {%- if template_mode == 'ornament' -%}
            Measure the head, neck, chest, waist or setup area where this ornament will sit.
          {%- else -%}
            Use the idol height from the product card or product fit panel as the first size signal.
          {%- endif -%}
        </p>
      </div>
      <div>
        <span>2</span>
        <strong>Check actual ornament measurement</strong>
        <p>Compare width, height, depth or arc with your idol's head, neck, chest, waist or setup area.</p>
      </div>
      <div>
        <span>3</span>
        <strong>
          {%- if template_mode == 'ornament' -%}
            Confirm deity compatibility
          {%- else -%}
            Match deity and placement
          {%- endif -%}
        </strong>
        <p>Deity-specific pieces should match the deity. General pieces can work when size and placement are right.</p>
      </div>
    </div>

    <div class="gc-deity-guide__fit-help" aria-label="Fit help before ordering">
      <div class="gc-deity-guide__fit-copy">
        <span>Fit help before ordering</span>
        <h3>Ask Anil to check size and use case</h3>
        <p>Share idol height, head or face width, the product link and one clear front photo. Golden Collections can help you compare the likely size, deity compatibility and placement before you order.</p>
      </div>
      <div class="gc-deity-guide__fit-links">
        <a href="{{ whatsapp_fit_url }}" target="_blank" rel="noopener">
          <strong>Ask Anil on WhatsApp</strong>
          <span>Best when you are unsure about size, deity match or ornament placement.</span>
        </a>
        <a href="{{ measure_url }}">
          <strong>How to choose size</strong>
          <span>Measure idol height, head width, chest, waist and altar space.</span>
        </a>
        <a href="{{ fit_process_url }}">
          <strong>How fit is checked</strong>
          <span>See the Golden Collections fit-check process used for deity jewellery.</span>
        </a>
        {%- if faq_family == 'varalakshmi' -%}
          <a href="{{ varalakshmi_examples_url }}">
            <strong>Varalakshmi fit examples</strong>
            <span>Watch real alankaram examples and the visible jewellery fit notes.</span>
          </a>
        {%- else -%}
          <a href="{{ proof_hub_url }}">
            <strong>Real alankaram examples</strong>
            <span>See permitted temple and festival examples where fit and placement are visible.</span>
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- if template_mode == 'ornament' -%}
      <div class="gc-deity-guide__advanced" aria-label="Advanced fit help">
        <div>
          <span>Advanced fit</span>
          <h3>Need a precise fit?</h3>
          <p>For close-fit crowns and custom idol setups, check arc length, inner circumference, depth and fastening method. If unsure, share idol photos and measurements before ordering.</p>
        </div>
        <div class="gc-deity-guide__measure-list" aria-label="Measurements to compare">
          <span>Head width</span>
          <span>Crown height</span>
          <span>Inner circumference</span>
          <span>Depth / fastening</span>
        </div>
      </div>
    {%- endif -%}

    {%- if has_regional_terms -%}
      <div class="gc-deity-guide__regional" aria-label="Regional and alternate names">
        <div>
          <span>Regional names</span>
          <h3>{{ section.settings.regional_heading | default: 'Names customers may search for' }}</h3>
        </div>
        <ul role="list">
          {%- if regional_keyword_list != blank -%}
            {%- for term in regional_keyword_list limit: 10 -%}
              <li>{{ term }}</li>
            {%- endfor -%}
          {%- elsif regional_keyword_text != blank -%}
            <li>{{ regional_keyword_text }}</li>
          {%- endif -%}
          {%- if deity_regional_names != blank -%}
            {%- for term in deity_regional_names limit: 8 -%}
              <li>{{ term }}</li>
            {%- endfor -%}
          {%- endif -%}
          {%- if deity_aliases != blank -%}
            {%- for term in deity_aliases limit: 6 -%}
              <li>{{ term }}</li>
            {%- endfor -%}
          {%- endif -%}
          {%- if ornament_aliases != blank -%}
            {%- for term in ornament_aliases limit: 6 -%}
              <li>{{ term }}</li>
            {%- endfor -%}
          {%- endif -%}
        </ul>
      </div>
    {%- endif -%}

    <div class="gc-deity-guide__bundles" aria-label="{% if template_mode == 'ornament' %}Related deity ornament collections{% else %}Complete alankaram setup{% endif %}">
      <div class="gc-deity-guide__bundles-head">
        <span>{{ bundle_label }}</span>
        <h3>{{ bundle_heading }}</h3>
        <p>{{ bundle_body }}</p>
      </div>
      <div class="gc-deity-guide__bundle-grid">
        <a href="{{ collection.url }}#ProductGridContainer">
          <strong>Choose exact-fit pieces</strong>
          <span>Stay in this collection and use the product grid filters for size, price and availability.</span>
        </a>
        {%- if has_setup_collections -%}
          {%- for setup_collection in setup_collections limit: 3 -%}
            {%- if setup_collection != blank and setup_collection.handle != collection.handle -%}
              {%- assign setup_title = setup_collection.metafields.custom.display_title.value | default: setup_collection.metafields.custom.display_title | default: setup_collection.title -%}
              <a href="{{ setup_collection.url }}">
                <strong>{{ setup_title | truncate: 48 }}</strong>
                <span>{{ setup_collection.metafields.custom.shopping_path_label.value | default: setup_collection.metafields.custom.collection_intro.value | default: setup_collection.description | strip_html | truncate: 90 }}</span>
              </a>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- if bundle_collection != blank and bundle_collection.handle != collection.handle -%}
            <a href="{{ bundle_collection.url }}">
              <strong>Varalakshmi setup</strong>
              <span>Full alankaram direction for festival dolls, idols, hands, legs and decoration.</span>
            </a>
          {%- endif -%}
          {%- if deity_root_collection != blank and deity_root_collection.handle != collection.handle -%}
            <a href="{{ deity_root_collection.url }}">
              <strong>All deity jewellery</strong>
              <span>Browse deity-first paths when you need crowns, harams, earrings and accessories together.</span>
            </a>
          {%- endif -%}
          {%- if crown_collection != blank and crown_collection.handle != collection.handle -%}
            <a href="{{ crown_collection.url }}">
              <strong>Add a crown</strong>
              <span>Check head width, crown height and idol posture before pairing with other ornaments.</span>
            </a>
          {%- elsif haram_collection != blank and haram_collection.handle != collection.handle -%}
            <a href="{{ haram_collection.url }}">
              <strong>Add a haram</strong>
              <span>Use chest width and drape length to complete the alankaram proportion.</span>
            </a>
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>

    <div class="gc-deity-guide__faq" aria-label="Deity jewellery size questions">
      <h3>{{ dynamic_faq_heading }}</h3>
      <div class="gc-deity-guide__faq-grid">
        <details>
          <summary>How do I choose deity jewellery size?</summary>
          <p>Start with the generally suitable idol size shown on the product, then compare the actual ornament measurement with your idol's head, neck, chest, waist or decoration area.</p>
        </details>

        {%- case faq_family -%}
          {%- when 'varalakshmi' -%}
            <details>
              <summary>What should I measure for Varalakshmi alankaram?</summary>
              <p>For Varalakshmi, check the idol or doll height, face width, crown height space, hand and leg placement, and the area where vagamalai or thomala will sit.</p>
            </details>
            <details>
              <summary>Can Amman or Lakshmi jewellery be used for Varalakshmi Vratham?</summary>
              <p>Many Amman and Lakshmi pieces can work for Varalakshmi Vratham when the deity style, placement and actual measurements match your idol or doll.</p>
            </details>
            <details>
              <summary>Should I buy a full setup or separate pieces?</summary>
              <p>Choose separate pieces when matching an existing idol. Choose a fuller setup when you want the face, crown, hands, legs, garlands and decoration to look coordinated.</p>
            </details>
          {%- when 'vishnu' -%}
            <details>
              <summary>How do I choose Vishnu or Perumal alankaram items?</summary>
              <p>Match the deity first, then check the product placement such as shankh chakra, arch, singhasan, taira, weapons or ornament position.</p>
            </details>
            <details>
              <summary>Are shankh chakra items only for Vishnu and Perumal?</summary>
              <p>Shankh chakra pieces are mainly selected for Vishnu, Perumal, Balaji and related forms. Use the measured product image to confirm the size suits your idol.</p>
            </details>
            <details>
              <summary>What should I check for arch, singhasan and stand items?</summary>
              <p>Check idol height, sitting or standing posture, base width and the available pooja mandir space before choosing arch, singhasan, cushion or stand items.</p>
            </details>
          {%- when 'crown' -%}
            <details>
              <summary>How do I choose the right deity crown or mukut size?</summary>
              <p>Measure your idol's head width and the height available above the head, then compare those measurements with the crown's width and height in the product images.</p>
            </details>
            <details>
              <summary>What is the difference between gold, stone and hair crowns?</summary>
              <p>Gold crowns give a traditional temple look, stone crowns add a decorative festive look, and hair crowns are chosen when the idol has a hair-style or back-head placement.</p>
            </details>
            <details>
              <summary>Will the same crown fit every idol of the same height?</summary>
              <p>No. Two idols with the same height can have different head width, face shape or hair style, so the actual crown measurement is the final fit check.</p>
            </details>
          {%- when 'necklace' -%}
            <details>
              <summary>How do I choose between short necklace and long haram?</summary>
              <p>Choose a short necklace for the neck or upper chest area, and a long haram when you want the jewellery to fall lower across the idol body or dress.</p>
            </details>
            <details>
              <summary>What measurements matter for deity necklaces?</summary>
              <p>Check idol height, neck or chest width, necklace drop length and the way the idol is dressed, because draping can change how the necklace sits.</p>
            </details>
            <details>
              <summary>Can one haram work for different god or goddess idols?</summary>
              <p>Yes, many deity harams are General/Common when the size and placement match. Deity-specific designs should be matched with the deity shown or mentioned.</p>
            </details>
          {%- when 'waist' -%}
            <details>
              <summary>How do I choose a deity waist belt or vaddanam?</summary>
              <p>Measure the idol's waist or dress width where the belt will sit, then compare it with the actual belt measurement and product image.</p>
            </details>
            <details>
              <summary>Does posture affect vaddanam fit?</summary>
              <p>Yes. Sitting idols, standing idols and dolls with wide dresses can need different belt lengths even if the idol height is similar.</p>
            </details>
            <details>
              <summary>Can deity waist belts be used for many goddesses?</summary>
              <p>Many waist belts are suitable for multiple goddess idols when the measured size, waist placement and decoration style match the idol.</p>
            </details>
          {%- when 'accessory' -%}
            <details>
              <summary>How do I choose small deity accessories like earrings, eyes or nose rings?</summary>
              <p>For small accessories, match the placement first, then compare the actual product measurement with the idol face, ears, eyes or decoration area.</p>
            </details>
            <details>
              <summary>Are these accessories deity-specific?</summary>
              <p>Some accessories are deity-specific, while others are General/Common. Use the product title, deity notes and measured images before ordering.</p>
            </details>
            <details>
              <summary>Why are measured images important for small accessories?</summary>
              <p>Small differences are very visible on idol faces and ornaments, so the measuring tape image helps confirm proportion before purchase.</p>
            </details>
          {%- when 'decor' -%}
            <details>
              <summary>How do I choose deity decoration items?</summary>
              <p>Check the idol height, base width, pooja mandir space and whether the item sits behind, beside, under or around the idol.</p>
            </details>
            <details>
              <summary>Can decorative items be used for many deities?</summary>
              <p>Many banana trees, lotus, stands, cushions and mandapam-style decor pieces are common for multiple deities when size and setup space are suitable.</p>
            </details>
            <details>
              <summary>What should I check before buying a stand or peedam?</summary>
              <p>Check the idol base size, weight, posture and available pooja space so the stand, peedam or asana supports the idol neatly.</p>
            </details>
          {%- else -%}
            <details>
              <summary>What does General/Common mean?</summary>
              <p>General/Common means the ornament can be used for many god or goddess idols when the measured size and placement are suitable.</p>
            </details>
            <details>
              <summary>Why does idol size matter?</summary>
              <p>The same idol height can have different head width, posture, waist shape or draping, so actual ornament measurement is the final fit check.</p>
            </details>
            <details>
              <summary>What should I check before ordering?</summary>
              <p>Check deity, ornament type, placement, generally suitable idol size, actual ornament measurement and the measuring tape product image.</p>
            </details>
        {%- endcase -%}

        <details>
          <summary>Can I get size help before buying?</summary>
          <p>Yes. Share your idol photo and measurements on WhatsApp so Golden Collections can help check likely fit before ordering.</p>
        </details>
      </div>
    </div>
  </div>
</section>

