{{ 'component-card.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign display_title = collection.metafields.custom.display_title.value | default: collection.metafields.custom.display_title | default: collection.title
  assign intro = collection.metafields.custom.collection_intro.value | default: collection.metafields.custom.collection_intro | default: collection.description | default: section.settings.intro
  assign mode = section.settings.mode
  assign collection_handle_lc = collection.handle | downcase
  assign child_collections = collection.metafields.custom.subcollections.value
  assign related_collections = collection.metafields.custom.related_collection_refs.value
  assign has_children = false
  assign has_related = false
  assign whatsapp_fit_text = 'Hello Golden Collections, I need Anil help choosing Bharatanatyam jewellery for ' | append: collection.title
  assign whatsapp_fit_encoded = whatsapp_fit_text | url_encode
  assign whatsapp_fit_url = 'https://wa.me/917337294499?text=' | append: whatsapp_fit_encoded

  if mode == 'auto'
    if collection_handle_lc contains 'black-kemp'
      assign mode = 'black_kemp'
    elsif collection_handle_lc contains 'kemp'
      assign mode = 'real_kemp'
    else
      assign mode = 'bharatanatyam'
    endif
  endif

  if child_collections != blank and child_collections.size > 0
    assign has_children = true
  endif

  if related_collections != blank and related_collections.size > 0
    assign has_related = true
  endif

  assign list_collections = child_collections
  if has_children == false and has_related
    assign list_collections = related_collections
  endif

  assign guide_heading = section.settings.guide_heading
  assign guide_body = section.settings.guide_body
  assign faq_heading = section.settings.faq_heading

  case mode
    when 'real_kemp'
      assign guide_heading = guide_heading | default: 'Premium kemp for arangetram and serious stage use'
      assign guide_body = guide_body | default: 'Real kemp jewellery is the premium South Indian temple and dance jewellery range. It is usually chosen for arangetram ceremonies, senior dancers, bridal classical styling and long-term performance use because the finish, base material and stone work are higher than regular Bharatanatyam/Kuchipudi jewellery.'
      assign faq_heading = faq_heading | default: 'Real kemp buying questions'
    when 'black_kemp'
      assign guide_heading = guide_heading | default: 'Black kemp styling for classical dance costumes'
      assign guide_body = guide_body | default: 'Black kemp jewellery is chosen when the dancer wants a stronger contrast with costume colors while keeping the Bharatanatyam and Kuchipudi temple jewellery look. Build the set by matching necklace, long haram, mattal, earrings, headset and vaddanam finishes.'
      assign faq_heading = faq_heading | default: 'Black kemp buying questions'
    else
      assign guide_heading = guide_heading | default: 'Dance jewellery paths for performance and arangetram'
      assign guide_body = guide_body | default: 'Start with the collection family: full dance sets for a complete stage look, short necklaces for upper chest placement, long harams for costume proportion, and accessories such as headset, nethi chutti, mattal, jada, rakodi and salangai for the final performance setup.'
      assign faq_heading = faq_heading | default: 'Bharatanatyam jewellery buying questions'
  endcase
-%}

<section class="gc-dance-hub color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    {%- if list_collections != blank and list_collections.size > 0 -%}
      <div class="gc-dance-hub__collections" aria-labelledby="gc-dance-hub-collections-heading">
        <div class="gc-dance-hub__head">
          <span>{{ section.settings.collections_eyebrow }}</span>
          <h2 id="gc-dance-hub-collections-heading">{{ section.settings.collections_heading }}</h2>
        </div>

        <ul
          class="gc-dance-hub__grid collection-list contains-card contains-card--collection{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid grid--3-col-desktop grid--2-col-tablet-down"
          role="list"
        >
          {%- for child_collection in list_collections limit: section.settings.max_collections -%}
            {%- if child_collection != blank -%}
              <li class="gc-dance-hub__collection-item collection-list__item grid__item">
                {% render 'card-collection',
                  card_collection: child_collection,
                  media_aspect_ratio: 'square',
                  columns: 3,
                  placeholder_image: 'collection-apparel-1'
                %}
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    <div class="gc-dance-hub__seo" aria-label="Dance performance buying help">
      <div class="gc-dance-hub__seo-copy">
        <span>{{ section.settings.guide_eyebrow }}</span>
        <h2>{{ guide_heading }}</h2>
        <p>{{ guide_body }}</p>
      </div>
      <ol class="gc-dance-hub__path" aria-label="Performance shopping path">
        {%- case mode -%}
          {%- when 'real_kemp' -%}
            <li>
              <strong>Choose the occasion</strong>
              <span>Arangetram, senior performance, bridal classical styling or long-term stage use.</span>
            </li>
            <li>
              <strong>Match the visible set</strong>
              <span>Keep necklace, haram, earrings, mattal, headset and vaddanam finish consistent.</span>
            </li>
            <li>
              <strong>Confirm premium care</strong>
              <span>Store dry, avoid perfume and water, and pack pieces separately after performance.</span>
            </li>
          {%- when 'black_kemp' -%}
            <li>
              <strong>Start with costume contrast</strong>
              <span>Check black kemp against costume body color, border and stage lighting.</span>
            </li>
            <li>
              <strong>Build one finish story</strong>
              <span>Match the darker kemp look across necklace, long haram, ear chains and waist belt.</span>
            </li>
            <li>
              <strong>Check dancer scale</strong>
              <span>Compare drop length, headset fit and waist belt size before buying components.</span>
            </li>
          {%- else -%}
            <li>
              <strong>Begin with the set</strong>
              <span>For arangetram, start with complete dance sets, then add missing hair or role pieces.</span>
            </li>
            <li>
              <strong>Balance necklace layers</strong>
              <span>Use short necklace for upper chest placement and long haram for costume proportion.</span>
            </li>
            <li>
              <strong>Finish the stage look</strong>
              <span>Add headset, nethi chutti, mattal, jada, rakodi, flowers and salangai as required.</span>
            </li>
        {%- endcase -%}
      </ol>
      <div class="gc-dance-hub__signals" aria-label="Collection buying signals">
        {%- case mode -%}
          {%- when 'real_kemp' -%}
            <span>Premium kemp range</span>
            <span>Arangetram ceremonies</span>
            <span>Kemp or Kempu stones</span>
            <span>Quality checked before packing</span>
          {%- when 'black_kemp' -%}
            <span>Black kemp styling</span>
            <span>Costume matching</span>
            <span>Dance sets and components</span>
            <span>Worldwide shipping</span>
          {%- else -%}
            <span>Regular and premium paths</span>
            <span>Kids and adult dancers</span>
            <span>Arangetram and stage use</span>
            <span>Bulk orders for institutes</span>
        {%- endcase -%}
      </div>

      <article class="gc-dance-hub__proof-card" aria-label="Dance community proof">
        <div>
          <span>Dance community proof</span>
          <h3>Golden Collections supported Aakara at Pearl '26</h3>
          <p>Our Bharatanatyam and Kuchipudi jewellery presence was shown during Aakara programming at BITS Pilani Hyderabad Campus, with gift items provided for Aakara winners.</p>
        </div>
        <a href="/blogs/jewellery-guides/golden-collections-sponsors-aakara-pearl-26-bits-pilani-hyderabad">Read the Aakara proof story</a>
      </article>

      <div class="gc-dance-hub__fit-help" aria-label="Bharatanatyam jewellery fit help">
        <div>
          <span>Fit and set planning</span>
          <h3>Ask Anil before choosing the final set</h3>
          <p>Share dancer age group, costume photos, performance date and the pieces already owned. Golden Collections can help compare scale, finish, stone color and missing components before ordering.</p>
        </div>
        <div class="gc-dance-hub__fit-actions">
          <a href="{{ whatsapp_fit_url }}" target="_blank" rel="noopener">Ask Anil on WhatsApp</a>
          <a href="/blogs/jewellery-guides/real-kemp-jewellery-guide">Real kemp guide</a>
          <a href="/blogs/jewellery-guides/real-kemp-jewellery-for-arangetram">Arangetram guide</a>
          <a href="/pages/anil-tunk">About Anil</a>
        </div>
      </div>
    </div>

    <div class="gc-dance-hub__faq" aria-label="Collection FAQ">
      <div class="gc-dance-hub__head">
        <span>{{ section.settings.faq_eyebrow }}</span>
        <h2>{{ faq_heading }}</h2>
      </div>

      <div class="gc-dance-hub__faq-list">
        {%- case mode -%}
          {%- when 'real_kemp' -%}
            <details>
              <summary>Why is real kemp jewellery costly?</summary>
              <p>Real kemp is a premium range compared with regular Bharatanatyam/Kuchipudi jewellery. It usually uses brass or copper bases, 24 carat high gold plating where confirmed, handcrafted temple motifs and Kemp or Kempu stones.</p>
            </details>
            <details>
              <summary>Is real kemp jewellery bought for arangetram?</summary>
              <p>Yes. Many customers choose real kemp for arangetram ceremonies, senior dance performances, bridal classical styling and long-term stage use because it has a richer premium temple jewellery look.</p>
            </details>
            <details>
              <summary>What is the difference between real kemp and regular Bharatanatyam/Kuchipudi jewellery?</summary>
              <p>Regular Bharatanatyam and Kuchipudi jewellery is usually alloy metal and more budget-friendly. Real kemp is the premium range with higher material and finish expectations.</p>
            </details>
            <details>
              <summary>How should real kemp jewellery be cared for?</summary>
              <p>Store it dry, keep it away from perfume, water and sweat after use, and wipe gently with a soft cloth before packing. Use separate storage so stones and plating do not rub against other ornaments.</p>
            </details>
            <details>
              <summary>Should I buy a full real kemp set or separate pieces?</summary>
              <p>For arangetram and major stage programs, a full matching set usually gives the cleanest look. Separate pieces work when the finish, stone color and size match your existing ornaments.</p>
            </details>
            <details>
              <summary>Can Golden Collections help match real kemp pieces?</summary>
              <p>Yes. Share costume photos, existing jewellery photos, dancer age group and performance timeline before ordering so the visible pieces can be matched more carefully.</p>
            </details>
          {%- when 'black_kemp' -%}
            <details>
              <summary>What is black kemp jewellery?</summary>
              <p>Black kemp jewellery is a classical dance jewellery style with a darker kemp look, chosen for costume contrast while keeping the Bharatanatyam and Kuchipudi temple jewellery language.</p>
            </details>
            <details>
              <summary>Is black kemp suitable for Bharatanatyam and Kuchipudi?</summary>
              <p>Yes. Black kemp sets and components can be used for Bharatanatyam and Kuchipudi when the costume color, dancer size and ornament placement match the performance look.</p>
            </details>
            <details>
              <summary>Can I mix black kemp with regular Bharatanatyam/Kuchipudi jewellery?</summary>
              <p>It is best to keep the visible set finish consistent, especially necklace, haram, earrings, mattal, headset and vaddanam. Mixing can work only when the colors and metal finish look intentional together.</p>
            </details>
            <details>
              <summary>What should I check before ordering black kemp?</summary>
              <p>Check whether you need a full set or only matching components, then compare necklace drop, waist belt length, headset fit, mattal length and costume colors before ordering.</p>
            </details>
            <details>
              <summary>Is black kemp better as a full set?</summary>
              <p>A full set is easier when the performance needs one consistent dark kemp finish. Components are useful when you are replacing or completing an existing black kemp look.</p>
            </details>
            <details>
              <summary>Does black kemp work for arangetram?</summary>
              <p>It can work when the teacher and costume direction call for the darker contrast. For arangetram, confirm the preferred jewellery color and complete component list before buying.</p>
            </details>
          {%- else -%}
            <details>
              <summary>What jewellery is included in a Bharatanatyam set?</summary>
              <p>A regular set usually includes long haram, short necklace, oddiyanam or vaddanam, vanki or bajuband, headset, nath, rakodi, bangles, earrings or jhumki, and mattal or matil. Some dancers also add jada, flowers, buns and ghungroo or salangai.</p>
            </details>
            <details>
              <summary>How do I choose Bharatanatyam jewellery for arangetram?</summary>
              <p>Start with a complete dance jewellery set, then confirm whether the costume needs matching jada accessories, rakodi, sun and moon, flowers, ghungroo or role-specific pieces such as a drama crown.</p>
            </details>
            <details>
              <summary>What is the difference between short necklace and long haram?</summary>
              <p>A short necklace sits near the neck or upper chest. A long haram falls lower across the costume and helps balance the full stage look.</p>
            </details>
            <details>
              <summary>Do you support dance institute bulk orders?</summary>
              <p>Yes. Golden Collections supports bulk orders for dance institutes. Share the required quantity, dancer age group, costume direction and timeline before ordering.</p>
            </details>
            <details>
              <summary>Can I buy Bharatanatyam jewellery one piece at a time?</summary>
              <p>Yes. Many dancers build from a complete set, then replace or add short necklace, long haram, mattal, headset, jada, rakodi, flowers or ghungroo as needed.</p>
            </details>
            <details>
              <summary>How do I match jewellery with costume color?</summary>
              <p>Match the metal finish and stone color across the visible pieces first. Then check necklace drop, waist belt placement, hair styling and stage lighting with the costume.</p>
            </details>
        {%- endcase -%}
      </div>
    </div>
  </div>
</section>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "CollectionPage",
        "@id": "{{ shop.url }}{{ collection.url }}#webpage",
        "url": "{{ shop.url }}{{ collection.url }}",
        "name": {{ display_title | json }},
        "description": {{ intro | strip_html | strip | default: guide_body | json }},
        "about": [
          { "@type": "Thing", "name": "Bharatanatyam jewellery" },
          { "@type": "Thing", "name": "Kuchipudi jewellery" },
          { "@type": "Thing", "name": "Classical dance jewellery" }
          {%- if mode == 'real_kemp' -%}
            ,{ "@type": "Thing", "name": "Real kemp jewellery" },
            { "@type": "Thing", "name": "Kemp stones" },
            { "@type": "Thing", "name": "Arangetram jewellery" }
          {%- elsif mode == 'black_kemp' -%}
            ,{ "@type": "Thing", "name": "Black kemp jewellery" },
            { "@type": "Thing", "name": "Dance costume accessories" }
          {%- else -%}
            ,{ "@type": "Thing", "name": "Temple jewellery" },
            { "@type": "Thing", "name": "Arangetram jewellery" }
          {%- endif -%}
        ],
        {%- if list_collections != blank and list_collections.size > 0 -%}
        "mainEntity": { "@id": "{{ shop.url }}{{ collection.url }}#collection-list" },
        {%- endif -%}
        "isPartOf": { "@id": "https://www.goldencollections.com/#website" }
      },
      {
        "@type": "BreadcrumbList",
        "@id": "{{ shop.url }}{{ collection.url }}#breadcrumb",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{ shop.url }}"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": {{ collection.title | json }},
            "item": "{{ shop.url }}{{ collection.url }}"
          }
        ]
      }
      {%- if list_collections != blank and list_collections.size > 0 -%},
      {
        "@type": "ItemList",
        "@id": "{{ shop.url }}{{ collection.url }}#collection-list",
        "name": {{ collection.title | append: ' collections' | json }},
        "itemListElement": [
          {%- for child_collection in list_collections limit: section.settings.max_collections -%}
            {%- assign child_title = child_collection.metafields.custom.display_title.value | default: child_collection.metafields.custom.display_title | default: child_collection.title -%}
            {
              "@type": "ListItem",
              "position": {{ forloop.index }},
              "url": "{{ shop.url }}{{ child_collection.url }}",
              "name": {{ child_title | json }}
            }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ]
      }
      {%- endif -%}
    ]
  }
</script>

