</section>

<script>
  (() => {
    const section = document.querySelector('[data-gc-measure-guide]');
    if (!section) return;
    const form = section.querySelector('[data-gc-measure-form]');
    const summary = section.querySelector('[data-gc-measure-summary]');
    const copyButton = section.querySelector('[data-gc-measure-copy]');
    const storageKey = 'gc-idol-measurement-checklist';

    const fields = [
      ['idolHeight', 'Idol height'],
      ['headWidth', 'Head/face width'],
      ['crownHeight', 'Crown space'],
      ['chestWidth', 'Neck/chest width'],
      ['haramDrop', 'Haram drop'],
      ['waistWidth', 'Waist placement'],
      ['fitNotes', 'Fit notes']
    ];

    const getValues = () => Object.fromEntries(new FormData(form).entries());
    const buildText = (values) => {
      const lines = fields
        .map(([name, label]) => values[name] ? `${label}: ${values[name]}` : '')
        .filter(Boolean);
      if (!lines.length) return 'Fill the checklist and save it to create a WhatsApp-ready summary.';
      return `Deity jewellery measurements:\n${lines.join('\n')}`;
    };
    const render = (values) => {
      if (!summary) return;
      summary.textContent = buildText(values);
    };

    try {
      const saved = JSON.parse(window.localStorage.getItem(storageKey) || '{}');
      for (const [name] of fields) {
        if (saved[name] && form.elements[name]) form.elements[name].value = saved[name];
      }
      render(saved);
    } catch (error) {
      render({});
    }

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const values = getValues();
      try {
        window.localStorage.setItem(storageKey, JSON.stringify(values));
      } catch (error) {}
      render(values);
    });

    if (copyButton) {
      copyButton.addEventListener('click', async () => {
        const text = buildText(getValues());
        try {
          await navigator.clipboard.writeText(text);
          copyButton.textContent = 'Copied';
          window.setTimeout(() => {
            copyButton.textContent = 'Copy WhatsApp summary';
          }, 1800);
        } catch (error) {
          render(getValues());
        }
      });
    }
  })();
</script>

