{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "vendor": {
          "type": "text",
          "disabled": true,
          "settings": {
            "text": "{{ product.vendor }}",
            "text_style": "uppercase"
          }
        },
        "title": {
          "type": "title",
          "settings": {}
        },
        "custom_liquid_PMjxQg": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% if product.metafields.custom.excerpt != blank %}\n  <p class=\"product__excerpt rte\">{{ product.metafields.custom.excerpt }}</p>\n{% endif %}"
          }
        },
        "price": {
          "type": "price",
          "settings": {}
        },
        "variant_picker": {
          "type": "variant_picker",
          "repeater": "{{ product.metafields.shopify[\"color-pattern\"].value }}",
          "settings": {
            "picker_type": "button",
            "swatch_shape": "circle"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector",
          "settings": {}
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": true
          }
        },
        "icon_with_text_MAyeen": {
          "type": "icon-with-text",
          "settings": {
            "layout": "horizontal",
            "icon_1": "heart",
            "heading_1": "Quality Checked",
            "icon_2": "check_mark",
            "heading_2": "5+ Quality Checks",
            "icon_3": "truck",
            "heading_3": "Free Delivery"
          }
        },
        "rating_WRGgPV": {
          "type": "rating",
          "settings": {}
        },
        "share": {
          "type": "share",
          "settings": {
            "share_label": "Share"
          }
        },
        "description": {
          "type": "description",
          "settings": {}
        }
      },
      "block_order": [
        "vendor",
        "title",
        "custom_liquid_PMjxQg",
        "price",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "icon_with_text_MAyeen",
        "rating_WRGgPV",
        "share",
        "description"
      ],
      "settings": {
        "enable_sticky_info": true,
        "color_scheme": "scheme-1",
        "media_size": "small",
        "constrain_to_viewport": false,
        "media_fit": "contain",
        "gallery_layout": "thumbnail_slider",
        "mobile_thumbnails": "hide",
        "media_position": "left",
        "image_zoom": "none",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 36,
        "padding_bottom": 12
      }
    },
    "dance_guide": {
      "type": "dance-product-guide",
      "settings": {
        "color_scheme": "scheme-1",
        "product_family": "real_kemp",
        "eyebrow": "Premium dance buying guide"
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "You may also like",
        "heading_size": "h2",
        "products_to_show": 4,
        "columns_desktop": 4,
        "columns_mobile": "2",
        "color_scheme": "scheme-1",
        "image_ratio": "square",
        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "padding_top": 36,
        "padding_bottom": 28
      }
    }
  },
  "order": [
    "main",
    "dance_guide",
    "related-products"
  ]
}
