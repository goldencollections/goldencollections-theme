{% comment %}
  Entries are managed in Shopify Admin under Content > Metaobjects > Glossary Term.
{% endcomment %}

{% layout 'page' %}

{%- liquid
  assign glossary_entries = shop.metaobjects.glossary_term.values | sort_natural: 'term.value'
  assign alphabet_csv = ''
  assign knowledge_url = pages['golden-collections-knowledge-hub'].url | default: '/pages/golden-collections-knowledge-hub'
  assign anil_url = pages['anil-tunk'].url | default: '/pages/anil-tunk'
  assign deity_hub_url = pages['deity-jewellery-alankaram-guide'].url | default: '/pages/deity-jewellery-alankaram-guide'
  assign crown_url = pages['deity-crown-mukut-kireedam-size-guide'].url | default: '/pages/deity-crown-mukut-kireedam-size-guide'
  assign lakshmi_url = pages['lakshmi-varalakshmi-deity-jewellery-guide'].url | default: '/pages/lakshmi-varalakshmi-deity-jewellery-guide'
  assign balaji_url = pages['balaji-vishnu-perumal-deity-jewellery-guide'].url | default: '/pages/balaji-vishnu-perumal-deity-jewellery-guide'
  assign process_url = pages['how-golden-collections-checks-deity-jewellery-fit'].url | default: '/pages/how-golden-collections-checks-deity-jewellery-fit'
-%}

{%- for entry in glossary_entries -%}
  {%- assign term_value = entry.term.value | default: '' | strip -%}
  {%- if term_value != blank -%}
    {%- assign letter = term_value | slice: 0, 1 | upcase -%}
    {%- assign letter_token = '|' | append: letter | append: '|' -%}
    {%- unless alphabet_csv contains letter_token -%}
      {%- assign alphabet_csv = alphabet_csv | append: letter_token -%}
    {%- endunless -%}
  {%- endif -%}
{%- endfor -%}
{%- assign alphabet_letters = alphabet_csv | split: '|' -%}

<section class="gc-glossary">
  <div class="gc-glossary__hero">
    <div class="page-width gc-glossary__hero-grid">
      <div>
        <nav class="gc-glossary__breadcrumb" aria-label="Breadcrumb">
          <a href="{{ routes.root_url }}">Home</a>
          <span>/</span>
          <span>Jewellery Glossary</span>
        </nav>
        <p class="gc-glossary__eyebrow">Golden Collections vocabulary hub</p>
        <h1>Temple, Deity and Classical Dance Jewellery Glossary</h1>
        <p class="gc-glossary__intro">A practical glossary for deity jewellery, Hindu idol alankaram, Bharatanatyam, Kuchipudi, real kemp and temple jewellery terms used by Golden Collections customers.</p>
        <div class="gc-glossary__actions">
          <a href="{{ deity_hub_url }}">Read deity guides</a>
          <a href="{{ knowledge_url }}" class="gc-glossary__secondary">Knowledge Hub</a>
        </div>
      </div>
      <aside class="gc-glossary__answer">
        <span>Direct answer</span>
        <p>This glossary helps customers connect regional jewellery names to the right buying context, so terms like mukut, kireedam, vaddanam, oddiyanam, thomala, namam and salangai are understood before purchase.</p>
      </aside>
    </div>
  </div>

  <div class="gc-glossary__body">
    <div class="page-width">
      <section class="gc-glossary__proof" aria-label="Glossary authority context">
        <article>
          <strong>Deity jewellery terms</strong>
          <span>Mukut, kireedam, haram, vaddanam, namam, shanku chakra and alankaram context.</span>
        </article>
        <article>
          <strong>Dance jewellery terms</strong>
          <span>Bharatanatyam, Kuchipudi, real kemp, nethi chutti, mattal, vanki and odiyanam context.</span>
        </article>
        <article>
          <strong>Fit-first guidance</strong>
          <span>Terms are tied back to measurement, deity compatibility and buying decisions.</span>
        </article>
      </section>

      <section class="gc-glossary__pathways" aria-labelledby="gc-glossary-pathways">
        <div>
          <p class="gc-glossary__eyebrow">Use the glossary with guides</p>
          <h2 id="gc-glossary-pathways">Start from the term, then verify fit</h2>
        </div>
        <div class="gc-glossary__path-grid">
          <a href="{{ crown_url }}">
            <strong>Mukut, Kireedam, Crown</strong>
            <span>Check crown style, head width, height, depth and altar clearance.</span>
          </a>
          <a href="{{ lakshmi_url }}">
            <strong>Hastham, Padam, Vaddanam</strong>
            <span>Use Lakshmi, Varalakshmi and Amman setup context before buying.</span>
          </a>
          <a href="{{ balaji_url }}">
            <strong>Namam, Thiruman, Shanku Chakra</strong>
            <span>Keep Vishnu-family symbols separate from general deity accessories.</span>
          </a>
          <a href="{{ process_url }}">
            <strong>Fit Check Process</strong>
            <span>See what photos and measurements help Golden Collections guide size.</span>
          </a>
        </div>
      </section>

      {%- if alphabet_csv != blank -%}
        <nav class="gc-glossary__nav" aria-label="Glossary letters">
          <p>Jump to letter</p>
          <ul>
            {%- for letter in alphabet_letters -%}
              {%- if letter != blank -%}
                <li><a href="#gc-letter-{{ letter | downcase }}">{{ letter }}</a></li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </nav>

        {%- for letter in alphabet_letters -%}
          {%- if letter == blank -%}{%- continue -%}{%- endif -%}
          <section id="gc-letter-{{ letter | downcase }}" class="gc-glossary-section">
            <h2>{{ letter }}</h2>
            <div class="gc-glossary__term-grid">
              {%- for entry in glossary_entries -%}
                {%- assign term_value = entry.term.value | default: '' | strip -%}
                {%- if term_value == blank -%}{%- continue -%}{%- endif -%}
                {%- assign first_letter = term_value | slice: 0, 1 | upcase -%}
                {%- if first_letter != letter -%}{%- continue -%}{%- endif -%}
                {%- assign entry_image = entry.image.value -%}
                <article class="gc-glossary__term-card">
                  <div class="gc-glossary__term-head">
                    {%- if entry_image != blank -%}
                      {{
                        entry_image
                        | image_url: width: 160
                        | image_tag:
                          class: 'gc-glossary__term-icon',
                          loading: 'lazy',
                          alt: term_value,
                          width: 80,
                          height: 80
                      }}
                    {%- endif -%}
                    <h3>{{ term_value | escape }}</h3>
                  </div>
                  {%- if entry.definition != blank -%}
                    <div class="gc-glossary__definition">
                      {{ entry.definition | metafield_tag }}
                    </div>
                  {%- endif -%}
                  {%- if entry.collection_link.value != blank -%}
                    <a href="{{ entry.collection_link.value | escape }}" class="gc-glossary__shop-link">Explore {{ term_value | escape }}</a>
                  {%- endif -%}
                </article>
              {%- endfor -%}
            </div>
          </section>
        {%- endfor -%}
      {%- else -%}
        <div class="gc-glossary__empty">
          <p>No glossary entries are available yet. Add entries under Content &gt; Metaobjects &gt; Glossary Term.</p>
        </div>
      {%- endif -%}

      <section class="gc-glossary__faq" aria-labelledby="gc-glossary-faq">
        <p class="gc-glossary__eyebrow">Glossary FAQ</p>
        <h2 id="gc-glossary-faq">How to use jewellery vocabulary safely</h2>
        <details open>
          <summary>Are mukut, kireedam and crown the same thing?</summary>
          <p>They often refer to deity head ornaments, but regional usage and crown style can differ. Always compare product photo, deity context and measurements.</p>
        </details>
        <details>
          <summary>Is vaddanam the same as oddiyanam?</summary>
          <p>Both can refer to waist ornaments, but usage changes across dance, bridal and deity jewellery contexts. Check placement and size before buying.</p>
        </details>
        <details>
          <summary>Can one regional name guarantee the right product?</summary>
          <p>No. A name helps you search, but fit depends on deity, idol size, posture, ornament type and product dimensions.</p>
        </details>
      </section>
    </div>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "{{ shop.url }}{{ page.url }}#webpage",
      "url": "{{ shop.url }}{{ page.url }}",
      "name": "Golden Collections Glossary of Temple and Classical Dance Jewellery",
      "description": "Glossary of deity jewellery, Hindu idol alankaram, Bharatanatyam, Kuchipudi, real kemp and temple jewellery terms curated by Golden Collections.",
      "author": { "@id": "{{ shop.url }}{{ anil_url }}#person" },
      "publisher": { "@id": "https://www.goldencollections.com/#organization" },
      "isPartOf": { "@id": "{{ shop.url }}{{ knowledge_url }}#webpage" }
    },
    {
      "@type": "DefinedTermSet",
      "@id": "{{ shop.url }}{{ page.url }}#defined-term-set",
      "name": "Golden Collections Jewellery Glossary",
      "url": "{{ shop.url }}{{ page.url }}"
    },
    {
      "@type": "FAQPage",
      "@id": "{{ shop.url }}{{ page.url }}#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Are mukut, kireedam and crown the same thing?",
          "acceptedAnswer": { "@type": "Answer", "text": "They often refer to deity head ornaments, but regional usage and crown style can differ. Always compare product photo, deity context and measurements." }
        },
        {
          "@type": "Question",
          "name": "Is vaddanam the same as oddiyanam?",
          "acceptedAnswer": { "@type": "Answer", "text": "Both can refer to waist ornaments, but usage changes across dance, bridal and deity jewellery contexts. Check placement and size before buying." }
        },
        {
          "@type": "Question",
          "name": "Can one regional name guarantee the right product?",
          "acceptedAnswer": { "@type": "Answer", "text": "No. A name helps you search, but fit depends on deity, idol size, posture, ornament type and product dimensions." }
        }
      ]
    }
  ]
}
</script>

<style>
  .gc-glossary {
    background: #fdf6ec;
    color: #1f170d;
    font-family: var(--font-body-family);
  }

  .gc-glossary__hero {
    background: #1a0e05;
    color: #f5ede0;
  }

  .gc-glossary__hero-grid {
    display: grid;
    gap: 1.5rem;
    padding: clamp(2rem, 5vw, 4.5rem) 0;
  }

  .gc-glossary__breadcrumb {
    color: rgba(245, 237, 224, 0.72);
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    font-size: 0.95rem;
    margin-bottom: 1.4rem;
  }

  .gc-glossary__breadcrumb a {
    color: #c9972a;
    text-decoration: none;
  }

  .gc-glossary__eyebrow {
    color: #c9972a;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin: 0 0 0.65rem;
    text-transform: uppercase;
  }

  .gc-glossary h1,
  .gc-glossary h2,
  .gc-glossary h3,
  .gc-glossary summary {
    font-family: var(--font-heading-family), Georgia, serif;
    letter-spacing: 0;
  }

  .gc-glossary h1 {
    color: #f5ede0;
    font-size: clamp(2.7rem, 5.6vw, 6.2rem);
    line-height: 0.98;
    margin: 0;
    max-width: 980px;
  }

  .gc-glossary__intro {
    color: rgba(245, 237, 224, 0.9);
    font-size: clamp(1.18rem, 1.4vw, 1.45rem);
    line-height: 1.58;
    margin: 1.2rem 0 0;
    max-width: 880px;
  }

  .gc-glossary__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .gc-glossary__actions a {
    align-items: center;
    background: #8b1c1c;
    border: 1px solid #8b1c1c;
    border-radius: 8px;
    color: #fffaf2;
    display: inline-flex;
    font-weight: 800;
    min-height: 48px;
    padding: 0.85rem 1rem;
    text-decoration: none;
  }

  .gc-glossary__actions .gc-glossary__secondary {
    background: transparent;
    border-color: rgba(201, 151, 42, 0.7);
    color: #f5ede0;
  }

  .gc-glossary__answer {
    align-self: end;
    background: #241508;
    border-left: 4px solid #c9972a;
    border-radius: 8px;
    padding: 1.2rem;
  }

  .gc-glossary__answer span {
    color: #c9972a;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .gc-glossary__answer p {
    color: #f5ede0;
    font-size: 1.2rem;
    line-height: 1.6;
    margin: 0.6rem 0 0;
  }

  .gc-glossary__body {
    padding: clamp(1.6rem, 4vw, 3.2rem) 0;
  }

  .gc-glossary__proof,
  .gc-glossary__path-grid,
  .gc-glossary__term-grid {
    display: grid;
    gap: 1rem;
  }

  .gc-glossary__proof article,
  .gc-glossary__pathways,
  .gc-glossary__term-card,
  .gc-glossary__faq,
  .gc-glossary__empty {
    background: #fffaf2;
    border: 1px solid rgba(201, 151, 42, 0.18);
    border-radius: 8px;
    box-shadow: 0 2px 10px rgba(26, 14, 4, 0.06);
    padding: 1.1rem;
  }

  .gc-glossary__proof article {
    border-left: 3px solid #c9972a;
    display: grid;
    gap: 0.35rem;
  }

  .gc-glossary__proof strong {
    font-size: 1.2rem;
  }

  .gc-glossary__proof span,
  .gc-glossary__path-grid span,
  .gc-glossary__definition,
  .gc-glossary__definition p,
  .gc-glossary__faq p,
  .gc-glossary__empty p {
    color: #4e4438;
    font-size: 1.06rem;
    line-height: 1.65;
  }

  .gc-glossary__pathways,
  .gc-glossary__nav,
  .gc-glossary-section,
  .gc-glossary__faq {
    margin-top: 1.3rem;
  }

  .gc-glossary__path-grid a,
  .gc-glossary__term-card {
    background: #fdf0d8;
    border-top: 3px solid #c9972a;
    color: #1f170d;
    display: grid;
    gap: 0.55rem;
    text-decoration: none;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .gc-glossary__path-grid a {
    border-radius: 8px;
    padding: 1rem;
  }

  .gc-glossary__path-grid a:hover,
  .gc-glossary__term-card:hover {
    box-shadow: 0 8px 18px rgba(26, 14, 4, 0.14);
    transform: translateY(-3px);
  }

  .gc-glossary__path-grid strong {
    font-family: var(--font-heading-family), Georgia, serif;
    font-size: 1.35rem;
  }

  .gc-glossary__nav {
    background: #241508;
    border-radius: 8px;
    padding: 1rem;
  }

  .gc-glossary__nav p {
    color: #f5ede0;
    font-weight: 800;
    margin: 0 0 0.7rem;
    text-align: center;
    text-transform: uppercase;
  }

  .gc-glossary__nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    justify-content: center;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .gc-glossary__nav a {
    background: #fffaf2;
    border: 1px solid rgba(201, 151, 42, 0.35);
    border-radius: 999px;
    color: #8b1c1c;
    display: inline-flex;
    font-weight: 800;
    min-width: 42px;
    padding: 0.45rem 0.75rem;
    text-decoration: none;
  }

  .gc-glossary-section {
    scroll-margin-top: 120px;
  }

  .gc-glossary-section h2 {
    color: #8b1c1c;
    font-size: clamp(2rem, 3vw, 3.2rem);
    margin: 0 0 0.8rem;
  }

  .gc-glossary__term-head {
    align-items: center;
    display: flex;
    gap: 0.8rem;
  }

  .gc-glossary__term-icon {
    aspect-ratio: 1;
    background: #fffaf2;
    border: 1px solid rgba(201, 151, 42, 0.24);
    border-radius: 50%;
    flex: 0 0 64px;
    height: 64px;
    object-fit: cover;
    width: 64px;
  }

  .gc-glossary__term-card h3 {
    font-size: 1.45rem;
    line-height: 1.15;
    margin: 0;
  }

  .gc-glossary__definition p:last-child {
    margin-bottom: 0;
  }

  .gc-glossary__shop-link {
    color: #8b1c1c;
    font-weight: 800;
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .gc-glossary details {
    border-top: 1px solid rgba(201, 151, 42, 0.24);
    padding: 1rem 0;
  }

  .gc-glossary summary {
    cursor: pointer;
    font-size: 1.25rem;
    font-weight: 800;
  }

  @media (prefers-reduced-motion: no-preference) {
    .gc-glossary__hero-grid > *,
    .gc-glossary__proof article,
    .gc-glossary__term-card {
      animation: gc-glossary-fade-up 0.55s ease-out both;
    }
  }

  @keyframes gc-glossary-fade-up {
    from {
      opacity: 0;
      transform: translateY(16px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (min-width: 750px) {
    .gc-glossary__hero-grid {
      grid-template-columns: minmax(0, 1.18fr) minmax(320px, 0.82fr);
    }

    .gc-glossary__proof {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .gc-glossary__path-grid,
    .gc-glossary__term-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 1100px) {
    .gc-glossary__term-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .gc-glossary__actions a {
      justify-content: center;
      width: 100%;
    }
  }
</style>
